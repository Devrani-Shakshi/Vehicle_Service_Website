@model IEnumerable<ServicePlatform.Models.Payment>
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "All Payments"; }

<div class="data-card animate-fadeInUp">
    <div class="data-card-header" style="display:flex; justify-content:space-between; align-items:center;">
        <h5 style="margin:0;"><i class="fas fa-credit-card" style="color:var(--accent);margin-right:8px;"></i>Payments</h5>
        <div style="display:flex; gap:10px; align-items:center;">
            <div style="position:relative;">
                <i class="fas fa-search" style="position:absolute; left:10px; top:50%; transform:translateY(-50%); color:var(--text-muted); font-size:0.85rem;"></i>
                <input type="text" id="paymentsSearch" class="form-control form-control-sm" placeholder="Search payments..." style="border-radius:20px; padding-left:30px; width:200px;" />
            </div>
            <button class="btn btn-sm" style="background:var(--primary-gradient);color:white;border:none;border-radius:6px;" onclick="exportTableToCSV('paymentsTable', 'Payments.csv')" data-bs-toggle="tooltip" title="Export to CSV"><i class="fas fa-download"></i></button>
        </div>
    </div>
    <table class="table-custom" id="paymentsTable">
        <thead><tr><th>Transaction</th><th>User</th><th>Amount</th><th>Gateway</th><th>Status</th><th>Date</th></tr></thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td style="font-family:monospace;font-size:0.8rem;">@(p.TransactionId?[..Math.Min(12, p.TransactionId.Length)] ?? "—")</td>
                    <td>@p.User.FullName</td>
                    <td style="font-weight:700;color:var(--success);">₹@p.Amount.ToString("N2")</td>
                    <td>@p.Gateway</td>
                    <td><span class="badge-custom badge-@p.Status.ToString().ToLower()">@p.Status</span></td>
                    <td style="font-size:0.8rem;color:var(--text-muted);">@p.CreatedAt.ToString("MMM dd, yyyy")</td>
                </tr>
            }
            @if (!Model.Any()) { <tr><td colspan="6" class="empty-state"><p>No payments</p></td></tr> }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            initTableSearch('paymentsSearch', 'paymentsTable');
        });
    </script>
}
