@model ServicePlatform.ViewModels.Admin.AdminDashboardViewModel
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Admin Dashboard"; }

<!-- Stats Grid -->
<div class="stats-grid">
    <a href="/Admin/Users?role=User" class="stat-card animate-fadeInUp" style="text-decoration:none;">
        <div class="stat-icon primary"><i class="fas fa-users"></i></div>
        <div class="stat-info"><h3>@Model.TotalUsers</h3><p>Total Users</p></div>
    </a>
    <a href="/Admin/Users?role=ServiceProvider" class="stat-card animate-fadeInUp-delay-1" style="text-decoration:none;">
        <div class="stat-icon success"><i class="fas fa-user-tie"></i></div>
        <div class="stat-info"><h3>@Model.TotalServiceProviders</h3><p>Service Providers</p></div>
    </a>
    <a href="/Admin/ServiceRequests" class="stat-card animate-fadeInUp-delay-2" style="text-decoration:none;">
        <div class="stat-icon warning"><i class="fas fa-clipboard-list"></i></div>
        <div class="stat-info"><h3>@Model.TotalServiceRequests</h3><p>Service Requests</p></div>
    </a>
    <a href="/Admin/Orders" class="stat-card animate-fadeInUp-delay-3" style="text-decoration:none;">
        <div class="stat-icon info"><i class="fas fa-shopping-bag"></i></div>
        <div class="stat-info"><h3>@Model.TotalOrders</h3><p>Total Orders</p></div>
    </a>
    <a href="/Admin/Payments" class="stat-card animate-fadeInUp-delay-4" style="text-decoration:none;">
        <div class="stat-icon danger"><i class="fas fa-indian-rupee-sign"></i></div>
        <div class="stat-info"><h3>₹@Model.TotalRevenue.ToString("N0")</h3><p>Total Revenue</p></div>
    </a>
    <div class="stat-card animate-fadeInUp-delay-4">
        <div class="stat-icon primary"><i class="fas fa-chart-line"></i></div>
        <div class="stat-info"><h3>₹@Model.MonthlyRevenue.ToString("N0")</h3><p>This Month</p></div>
    </div>
</div>

<!-- Charts Row -->
<div style="display:grid;grid-template-columns:2fr 1fr;gap:1.5rem;margin-bottom:1.5rem;">
    <div class="chart-container animate-fadeInUp-delay-2">
        <h5><i class="fas fa-chart-area" style="color:var(--primary-light);"></i> Revenue Trend (6 Months)</h5>
        <canvas id="revenueChart" height="120"></canvas>
    </div>
    <div class="chart-container animate-fadeInUp-delay-3">
        <h5><i class="fas fa-chart-pie" style="color:var(--success);"></i> Request Status</h5>
        <canvas id="statusChart" height="200"></canvas>
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem;">
    <div class="chart-container animate-fadeInUp-delay-3">
        <h5><i class="fas fa-chart-bar" style="color:var(--accent);"></i> Service Activity</h5>
        <canvas id="activityChart" height="150"></canvas>
    </div>
    <div class="chart-container animate-fadeInUp-delay-4">
        <h5><i class="fas fa-user-plus" style="color:var(--info);"></i> User Growth</h5>
        <canvas id="growthChart" height="150"></canvas>
    </div>
</div>

<!-- Recent Activity Tables -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;">
    <div class="data-card">
        <div class="data-card-header">
            <h5><i class="fas fa-clipboard-list" style="color:var(--primary-light);margin-right:8px;"></i>Recent Requests</h5>
            <a href="/Admin/ServiceRequests" style="font-size:0.8rem;">View All</a>
        </div>
        <table class="table-custom">
            <thead><tr><th>Title</th><th>User</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var r in Model.RecentRequests)
                {
                    <tr onclick="window.location='/Admin/ServiceRequestDetails/@r.Id'" style="cursor:pointer;" title="Click to view details">
                        <td style="font-weight:600;color:var(--primary-light);">@r.Title</td>
                        <td>@r.UserName</td>
                        <td><span class="badge-custom badge-@r.Status.ToLower()">@r.Status</span></td>
                    </tr>
                }
                @if (!Model.RecentRequests.Any())
                {
                    <tr><td colspan="3" class="text-center" style="color:var(--text-muted);padding:2rem;">No requests yet</td></tr>
                }
            </tbody>
        </table>
    </div>
    <div class="data-card">
        <div class="data-card-header">
            <h5><i class="fas fa-shopping-bag" style="color:var(--success);margin-right:8px;"></i>Recent Orders</h5>
            <a href="/Admin/Orders" style="font-size:0.8rem;">View All</a>
        </div>
        <table class="table-custom">
            <thead><tr><th>Order #</th><th>Customer</th><th>Amount</th></tr></thead>
            <tbody>
                @foreach (var o in Model.RecentOrders)
                {
                    <tr onclick="window.location='/Admin/OrderDetails/@o.Id'" style="cursor:pointer;" title="Click to view details">
                        <td style="font-family:monospace;font-size:0.8rem;color:var(--success-light);">@o.OrderNumber</td>
                        <td>@o.CustomerName</td>
                        <td style="font-weight:700;color:var(--success);">₹@o.Amount.ToString("N0")</td>
                    </tr>
                }
                @if (!Model.RecentOrders.Any())
                {
                    <tr><td colspan="3" class="text-center" style="color:var(--text-muted);padding:2rem;">No orders yet</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // Revenue Chart
        const revenueCtx = document.getElementById('revenueChart').getContext('2d');
        new Chart(revenueCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueData.Select(r => r.Month))),
                datasets: [{
                    label: 'Revenue (₹)',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueData.Select(r => r.Amount))),
                    borderColor: '#6366f1',
                    backgroundColor: 'rgba(99, 102, 241, 0.1)',
                    fill: true,
                    tension: 0.4,
                    borderWidth: 3,
                    pointBackgroundColor: '#6366f1',
                    pointBorderColor: '#fff',
                    pointRadius: 5
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { labels: { color: '#94a3b8' } } },
                scales: {
                    x: { ticks: { color: '#64748b' }, grid: { color: 'rgba(51,65,85,0.5)' } },
                    y: { ticks: { color: '#64748b' }, grid: { color: 'rgba(51,65,85,0.5)' } }
                }
            }
        });

        // Status Doughnut
        const statusCtx = document.getElementById('statusChart').getContext('2d');
        new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: ['Pending', 'Completed', 'Others'],
                datasets: [{
                    data: [@Model.PendingRequests, @Model.CompletedRequests, @(Model.TotalServiceRequests - Model.PendingRequests - Model.CompletedRequests)],
                    backgroundColor: ['#f59e0b', '#10b981', '#6366f1'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom', labels: { color: '#94a3b8', padding: 15 } } },
                cutout: '65%'
            }
        });

        // Activity Chart
        const activityCtx = document.getElementById('activityChart').getContext('2d');
        new Chart(activityCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ServiceActivityData.Select(a => a.Month))),
                datasets: [{
                    label: 'Requests', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ServiceActivityData.Select(a => a.Requests))),
                    backgroundColor: '#6366f1', borderRadius: 6
                }, {
                    label: 'Completed', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ServiceActivityData.Select(a => a.Completed))),
                    backgroundColor: '#10b981', borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { labels: { color: '#94a3b8' } } },
                scales: {
                    x: { ticks: { color: '#64748b' }, grid: { display: false } },
                    y: { ticks: { color: '#64748b' }, grid: { color: 'rgba(51,65,85,0.5)' } }
                }
            }
        });

        // Growth Chart
        const growthCtx = document.getElementById('growthChart').getContext('2d');
        new Chart(growthCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.UserGrowthData.Select(g => g.Month))),
                datasets: [{
                    label: 'New Users', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.UserGrowthData.Select(g => g.Users))),
                    borderColor: '#3b82f6', backgroundColor: 'rgba(59, 130, 246, 0.1)', fill: true, tension: 0.4, borderWidth: 3
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { labels: { color: '#94a3b8' } } },
                scales: {
                    x: { ticks: { color: '#64748b' }, grid: { color: 'rgba(51,65,85,0.5)' } },
                    y: { ticks: { color: '#64748b' }, grid: { color: 'rgba(51,65,85,0.5)' } }
                }
            }
        });
    </script>
}
