@model ServicePlatform.ViewModels.Admin.AdminDashboardViewModel
@inject IConfiguration Configuration
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Admin Dashboard"; var commRate = Configuration.GetValue<int>("GlobalSettings:CommissionRate", 5); }

<h4 class="animate-fadeInUp" style="margin-bottom:0.25rem;">Governance &amp; Finance Hub</h4>
<p class="animate-fadeInUp" style="color:var(--text-muted);margin-bottom:2rem;">Monitor platform growth and @commRate% vendor commissions.</p>

<!-- Stats Grid -->
<div class="stats-grid animate-fadeInUp-delay-1" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
    <div class="stat-card">
        <div class="stat-icon primary"><i class="fas fa-users"></i></div>
        <div class="stat-info">
            <h3>@Model.TotalUsers</h3>
            <p>Total E-Vehicle Users</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon info"><i class="fas fa-store"></i></div>
        <div class="stat-info">
            <h3>@Model.TotalShopkeepers</h3>
            <p>Verified Shopkeepers</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon warning"><i class="fas fa-tools"></i></div>
        <div class="stat-info">
            <h3>@Model.TotalServiceProviders</h3>
            <p>System Providers</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon success"><i class="fas fa-wallet"></i></div>
        <div class="stat-info">
            <h3>₹@Model.TotalPlatformRevenue.ToString("N0")</h3>
            <p>Archived Platform Revenue</p>
        </div>
    </div>
</div>

<div class="stats-grid animate-fadeInUp-delay-2" style="grid-template-columns: repeat(2, 1fr); margin-top:1.5rem;">
    <div class="stat-card" style="background:var(--bg-card); border: 2px solid var(--primary-light);">
        <div class="stat-icon success"><i class="fas fa-calendar-check"></i></div>
        <div class="stat-info">
            <h3>₹@Model.MonthlyPlatformRevenue.ToString("N0")</h3>
            <p>Revenue This Month</p>
        </div>
    </div>
    <div class="stat-card" style="background:var(--bg-card); border: 2px solid var(--danger);">
        <div class="stat-icon danger"><i class="fas fa-clock"></i></div>
        <div class="stat-info">
            <h3 style="color:var(--danger);">₹@Model.PendingCommissionAmount.ToString("N0")</h3>
            <p>Pending Dues from Vendors</p>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div style="display:grid; grid-template-columns: 2fr 1fr; gap:1.5rem; margin-top:2rem;">
    <!-- Revenue Chart -->
    <div class="data-card animate-fadeInUp-delay-3" style="min-height: 350px;">
        <div class="data-card-header">
            <h5><i class="fas fa-chart-line" style="color:var(--primary-light);margin-right:8px;"></i>Platform Revenue Trend (@commRate%)</h5>
        </div>
        <div class="data-card-body" style="position:relative; height: 300px;">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>

    <!-- Active Vendor Activity -->
    <div class="data-card animate-fadeInUp-delay-3" style="min-height: 350px;">
        <div class="data-card-header">
            <h5><i class="fas fa-user-plus" style="color:var(--info);margin-right:8px;"></i>User Growth</h5>
        </div>
        <div class="data-card-body" style="position:relative; height: 300px;">
            <canvas id="userGrowthChart"></canvas>
        </div>
    </div>
</div>

<!-- Recent Collections Row -->
<div class="data-card animate-fadeInUp-delay-4" style="margin-top:2rem;">
    <div class="data-card-header" style="display:flex; justify-content:space-between; align-items:center;">
        <h5 style="margin:0;"><i class="fas fa-money-check-alt" style="color:var(--success);margin-right:8px;"></i>Recent Vendor Collections</h5>
        <a href="/Admin/Commissions" class="btn-outline-custom" style="padding:4px 12px;font-size:0.8rem;">View All</a>
    </div>
    <table class="table-custom">
        <thead>
            <tr>
                <th>Vendor</th>
                <th>Billing Cycle</th>
                <th>@commRate% Due</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.RecentCommissions)
            {
                <tr>
                    <td style="font-weight:600;">@c.VendorName</td>
                    <td>@c.MonthYear</td>
                    <td style="font-weight:700;color:var(--success);">₹@c.Amount.ToString("N0")</td>
                    <td>
                        <span class="badge-custom badge-@(c.Status == "Paid" ? "success" : "warning")">@c.Status</span>
                    </td>
                </tr>
            }
            @if (!Model.RecentCommissions.Any())
            {
                <tr><td colspan="4" class="empty-state"><p>No collections recorded yet.</p></td></tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Data loading
            const revenueData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueData));
            const userGrowthData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.UserGrowthData));

            // Theme handling for charts
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            const textColor = isDark ? '#94a3b8' : '#64748b';
            const gridColor = isDark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)';

            // Common Options
            const commonOptions = {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } }, // we hide legend for cleaner look
                scales: {
                    x: { grid: { display: false }, ticks: { color: textColor } },
                    y: { grid: { color: gridColor }, ticks: { color: textColor } }
                }
            };

            // 1. Revenue Chart
            const revCtx = document.getElementById('revenueChart').getContext('2d');
            const revGradient = revCtx.createLinearGradient(0, 0, 0, 300);
            revGradient.addColorStop(0, 'rgba(99, 102, 241, 0.5)');
            revGradient.addColorStop(1, 'rgba(99, 102, 241, 0.0)');
            
            new Chart(revCtx, {
                type: 'line',
                data: {
                    labels: revenueData.map(d => d.Month),
                    datasets: [{
                        label: 'Platform Revenue (₹)',
                        data: revenueData.map(d => d.Amount),
                        borderColor: '#6366f1', borderWidth: 3, 
                        backgroundColor: revGradient, fill: true,
                        tension: 0.4, pointRadius: 4, pointBackgroundColor: '#6366f1'
                    }]
                },
                options: commonOptions
            });

            // 2. User Growth Chart
            const usrCtx = document.getElementById('userGrowthChart').getContext('2d');
            new Chart(usrCtx, {
                type: 'bar',
                data: {
                    labels: userGrowthData.map(d => d.Month),
                    datasets: [{
                        label: 'New Users',
                        data: userGrowthData.map(d => d.Users),
                        backgroundColor: '#10b981', borderRadius: 4
                    }]
                },
                options: commonOptions
            });
        });
    </script>
}
