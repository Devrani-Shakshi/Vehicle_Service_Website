@model IEnumerable<ServicePlatform.Models.ApplicationUser>
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = ViewBag.SelectedRole == null ? "All Users" : $"{ViewBag.SelectedRole}s"; }

<div class="data-card animate-fadeInUp">
    <div class="data-card-header" style="display:flex; justify-content:space-between; align-items:center;">
        <h5 style="margin:0;"><i class="fas fa-users" style="margin-right:8px;"></i>@ViewData["Title"]</h5>
        <a href="@Url.Action("CreateUser", "Admin")" class="btn btn-primary-custom btn-sm"><i class="fas fa-plus"></i> Add New User</a>
    </div>
    <div class="data-card-body">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Mobile</th>
                    <th>Status</th>
                    <th>Registered</th>
                    <th style="text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td style="font-weight:600;">@user.FullName</td>
                        <td>@user.Email</td>
                        <td>@(user.Mobile ?? "N/A")</td>
                        <td>
                            <span class="badge-custom badge-@(user.IsActive ? "success" : "danger")">
                                @(user.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td style="font-size:0.8rem;color:var(--text-muted);">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td style="text-align:right;">
                            <div style="display:flex; gap:8px; justify-content:flex-end;">
                                <a href="@Url.Action("EditUser", "Admin", new { id = user.Id })" class="btn btn-xs btn-outline-primary"><i class="fas fa-edit"></i></a>
                                <form asp-action="ToggleUserStatus" asp-route-id="@user.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-xs @(user.IsActive ? "btn-outline-warning" : "btn-outline-success")" title="@(user.IsActive ? "Deactivate" : "Activate")">
                                        <i class="fas @(user.IsActive ? "fa-user-slash" : "fa-user-check")"></i>
                                    </button>
                                </form>
                                <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this user?');">
                                    <button type="submit" class="btn btn-xs btn-outline-danger"><i class="fas fa-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <!-- Pagination -->
    <div style="padding:1.5rem;display:flex;justify-content:center;gap:0.5rem;border-top:1px solid var(--border-color);">
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            <a href="/Admin/Users?role=@ViewBag.SelectedRole&page=@i" class="btn-outline-custom @(i == ViewBag.CurrentPage ? "active" : "")" style="padding:8px 16px;text-decoration:none;">@i</a>
        }
    </div>
</div>
