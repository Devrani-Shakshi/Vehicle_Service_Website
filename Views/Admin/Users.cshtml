@using Microsoft.AspNetCore.Identity
@using ServicePlatform.Models
@inject UserManager<ApplicationUser> UserManager
@model IEnumerable<ApplicationUser>
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "User Management"; }

<div class="data-card animate-fadeInUp">
    <div class="data-card-header" style="display:flex; justify-content:space-between; align-items:center;">
        <h5 style="margin:0;"><i class="fas fa-users-cog" style="color:var(--primary-light);margin-right:8px;"></i>Users</h5>
        <div style="display:flex; gap:12px; align-items:center;">
            <div class="btn-group btn-group-sm" role="group">
                <a href="/Admin/Users" class="btn btn-outline-primary @(ViewBag.SelectedRole == null ? "active" : "")">All</a>
                <a href="/Admin/Users?role=User" class="btn btn-outline-primary @(ViewBag.SelectedRole == "User" ? "active" : "")">Users</a>
                <a href="/Admin/Users?role=ServiceProvider" class="btn btn-outline-primary @(ViewBag.SelectedRole == "ServiceProvider" ? "active" : "")">Providers</a>
                <a href="/Admin/Users?role=Shopkeeper" class="btn btn-outline-primary @(ViewBag.SelectedRole == "Shopkeeper" ? "active" : "")">Shopkeepers</a>
            </div>
            <div style="position:relative;">
                <i class="fas fa-search" style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--text-muted); font-size:0.85rem;"></i>
                <input type="text" id="userSearch" class="form-control form-control-sm" placeholder="Search..." style="border-radius:20px; padding-left:32px; width:200px;" />
            </div>
        </div>
    </div>
    <table class="table-custom" id="userTable">
        <thead><tr><th>Full Name</th><th>Email</th><th>Role</th><th>Joined</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td style="font-weight:600;">@user.FullName</td>
                    <td>@user.Email</td>
                    <td>
                        @{
                            var roles = await UserManager.GetRolesAsync(user);
                            var userRole = roles.FirstOrDefault() ?? "User";
                        }
                        <span class="badge-custom badge-info">@userRole</span>
                    </td>
                    <td style="font-size:0.8rem;color:var(--text-muted);">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td>
                        <span class="badge-custom badge-@(user.IsActive ? "success" : "danger")">
                            @(user.IsActive ? "Active" : "Blocked")
                        </span>
                    </td>
                    <td>
                        <form asp-action="ToggleUserStatus" method="post" style="display:inline;">
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit" class="btn btn-xs @(user.IsActive ? "btn-outline-danger" : "btn-outline-success")" style="padding: 2px 8px; font-size: 0.75rem; border-radius: 4px;">
                                <i class="fas fa-@(user.IsActive ? "user-slash" : "user-check")"></i> @(user.IsActive ? "Block" : "Unblock")
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            initTableSearch('userSearch', 'userTable');
        });
    </script>
}
