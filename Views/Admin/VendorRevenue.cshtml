@model IEnumerable<ServicePlatform.Models.Commission>
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Vendor Revenue"; }

<div class="data-card animate-fadeInUp">
    <div class="data-card-header" style="display:block;padding:1.5rem;">
        <h5 style="margin-bottom:1rem;"><i class="fas fa-wallet" style="color:var(--success);margin-right:8px;"></i>Vendor Revenue Report</h5>
        <form method="get" asp-action="VendorRevenue" style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;">
            <select name="vendorId" class="form-control" style="width:auto;min-width:200px;">
                <option value="">All Vendors</option>
                @if (ViewBag.Vendors != null)
                {
                    @foreach (var v in (IEnumerable<dynamic>)ViewBag.Vendors)
                    {
                        <option value="@v.Id" selected="@(ViewBag.SelectedVendor == v.Id ? "selected" : null)">@v.FullName</option>
                    }
                }
            </select>
            <select name="month" class="form-control" style="width:auto;">
                <option value="">All Months</option>
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m" selected="@(ViewBag.SelectedMonth != null && (int)ViewBag.SelectedMonth == m ? "selected" : null)">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                }
            </select>
            <select name="year" class="form-control" style="width:auto;">
                <option value="">All Years</option>
                @for (int y = DateTime.Now.Year; y >= 2024; y--)
                {
                    <option value="@y" selected="@(ViewBag.SelectedYear != null && (int)ViewBag.SelectedYear == y ? "selected" : null)">@y</option>
                }
            </select>
            <button type="submit" class="btn-primary-custom" style="padding:8px 20px;font-size:0.85rem;"><i class="fas fa-filter"></i> Filter</button>
        </form>
    </div>
    <table class="table-custom">
        <thead><tr><th>Vendor</th><th>Role</th><th>Month</th><th>Year</th><th>Total Income</th><th>Commission</th><th>Status</th></tr></thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td style="font-weight:600;">@(c.User?.FullName ?? "—")</td>
                    <td>@c.Role</td>
                    <td>@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(c.Month)</td>
                    <td>@c.Year</td>
                    <td style="color:var(--success);font-weight:600;">₹@c.TotalIncome.ToString("N0")</td>
                    <td style="color:var(--danger);">₹@c.CommissionAmount.ToString("N0")</td>
                    <td><span class="badge-custom @(c.IsPaid ? "badge-completed" : "badge-pending")">@(c.IsPaid ? "Paid" : "Pending")</span></td>
                </tr>
            }
            @if (!Model.Any()) { <tr><td colspan="7" class="empty-state"><i class="fas fa-chart-pie"></i><h5>No data</h5><p>Adjust filters or wait for commission calculation</p></td></tr> }
        </tbody>
    </table>
</div>
