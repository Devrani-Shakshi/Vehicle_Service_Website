@model IEnumerable<ServicePlatform.Models.Feedback>
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Feedback Management"; }

<div class="data-card animate-fadeInUp">
    <div class="data-card-header"><h5><i class="fas fa-comments" style="color:var(--primary-light);margin-right:8px;"></i>User Feedback</h5></div>
    <table class="table-custom">
        <thead><tr><th>User</th><th>Subject</th><th>Message</th><th>Status</th><th>Date</th><th>Action</th></tr></thead>
        <tbody>
            @foreach (var f in Model)
            {
                <tr>
                    <td>@f.User.FullName</td>
                    <td style="font-weight:600;">@f.Subject</td>
                    <td style="max-width:200px;font-size:0.85rem;color:var(--text-secondary);">@(f.Message.Length > 80 ? f.Message[..80] + "..." : f.Message)</td>
                    <td><span class="badge-custom @(f.IsResolved ? "badge-completed" : "badge-pending")">@(f.IsResolved ? "Resolved" : "Pending")</span></td>
                    <td style="font-size:0.8rem;color:var(--text-muted);">@f.CreatedAt.ToString("MMM dd")</td>
                    <td>
                        @if (!f.IsResolved)
                        {
                            <form asp-action="ResolveFeedback" method="post" style="display:flex;gap:6px;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@f.Id" />
                                <input name="adminResponse" class="form-control" style="background:var(--bg-input);border:1px solid var(--border-color);color:var(--text-primary);padding:6px 10px;font-size:0.8rem;border-radius:6px;width:150px;" placeholder="Response..." />
                                <button type="submit" class="btn-success-custom" style="padding:6px 14px;font-size:0.8rem;"><i class="fas fa-check"></i></button>
                            </form>
                        }
                        else { <span style="font-size:0.8rem;color:var(--text-muted);">@f.AdminResponse</span> }
                    </td>
                </tr>
            }
            @if (!Model.Any()) { <tr><td colspan="6" class="empty-state"><p>No feedback</p></td></tr> }
        </tbody>
    </table>
</div>
