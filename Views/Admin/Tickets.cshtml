@model IEnumerable<ServicePlatform.Models.SupportTicket>
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Support Tickets"; }

<div class="data-card animate-fadeInUp">
    <div class="data-card-header">
        <h5><i class="fas fa-headset" style="color:var(--primary-light);margin-right:8px;"></i>Dispute Resolution</h5>
        <div style="display:flex;gap:8px;">
            <a href="/Admin/Tickets" class="btn-outline-custom @(ViewContext.HttpContext.Request.Query["status"].Count == 0 ? "active" : "")" style="padding:6px 14px;font-size:0.8rem;">All</a>
            <a href="/Admin/Tickets?status=Open" class="btn-outline-custom" style="padding:6px 14px;font-size:0.8rem;">Open</a>
            <a href="/Admin/Tickets?status=Resolved" class="btn-outline-custom" style="padding:6px 14px;font-size:0.8rem;">Resolved</a>
        </div>
    </div>
    <table class="table-custom">
        <thead><tr><th>#</th><th>User</th><th>Subject</th><th>Category</th><th>Status</th><th>Date</th><th>Action</th></tr></thead>
        <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td>@t.Id</td>
                    <td style="font-weight:600;">@(t.User?.FullName ?? "—")</td>
                    <td>@t.Subject</td>
                    <td>@t.Category</td>
                    <td><span class="badge-custom @(t.Status == ServicePlatform.Models.TicketStatus.Resolved ? "badge-completed" : "badge-pending")">@t.Status</span></td>
                    <td>@t.CreatedAt.ToString("dd MMM")</td>
                    <td>
                        @if (t.Status != ServicePlatform.Models.TicketStatus.Resolved)
                        {
                            <button type="button" class="btn-primary-custom" style="padding:6px 14px;font-size:0.8rem;" onclick="document.getElementById('resolve-@t.Id').style.display='block'"><i class="fas fa-reply"></i></button>
                        }
                        else { <span style="font-size:0.8rem;color:var(--text-muted);">Done</span> }
                    </td>
                </tr>
                @if (t.Status != ServicePlatform.Models.TicketStatus.Resolved)
                {
                    <tr id="resolve-@t.Id" style="display:none;">
                        <td colspan="7">
                            <form asp-action="ResolveTicket" method="post" style="display:flex;gap:8px;align-items:center;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@t.Id" />
                                <p style="margin:0;font-size:0.85rem;min-width:60px;"><strong>Issue:</strong> @t.Description</p>
                                <input type="text" name="response" class="form-control" placeholder="Your response..." style="flex:1;" required />
                                <button type="submit" class="btn-primary-custom" style="padding:8px 16px;font-size:0.85rem;white-space:nowrap;"><i class="fas fa-check"></i> Resolve</button>
                            </form>
                        </td>
                    </tr>
                }
            }
            @if (!Model.Any()) { <tr><td colspan="7" class="empty-state"><i class="fas fa-inbox"></i><h5>No tickets</h5><p>No support requests found</p></td></tr> }
        </tbody>
    </table>
</div>
