@model ServicePlatform.Models.GlobalSetting
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Revenue Settings"; }

<div style="width:100%;max-width:600px;margin:0 auto;padding-bottom:2rem;">
    <div class="data-card animate-fadeInUp">
        <div class="data-card-header"><h5><i class="fas fa-percentage" style="color:var(--success);margin-right:8px;"></i>Commission Rate Settings</h5></div>
        <div class="data-card-body" style="padding:2rem;">
            <div style="background:var(--bg-secondary);border-radius:var(--radius-md);padding:1.5rem;margin-bottom:1.5rem;text-align:center;">
                <p style="color:var(--text-muted);font-size:0.85rem;margin:0;">Current Commission Rate</p>
                <p style="font-size:2.5rem;font-weight:700;color:var(--primary-light);margin:0.5rem 0;">@(Model?.Value ?? "10")%</p>
                @if (Model != null) {
                    <p style="font-size:0.75rem;color:var(--text-muted);margin:0;">Last updated: @Model.UpdatedAt.ToString("dd MMM yyyy HH:mm")</p>
                }
            </div>
            <form asp-action="RevenueSettings" method="post">
                @Html.AntiForgeryToken()
                <div class="form-floating-custom">
                    <label>New Commission Rate (%)</label>
                    <input type="number" name="rate" class="form-control" min="0" max="50" step="0.5" value="@(Model?.Value ?? "10")" />
                </div>
                <button type="submit" class="btn-primary-custom" style="width:100%;justify-content:center;margin-top:1rem;"><i class="fas fa-save"></i> Update Rate</button>
            </form>
        </div>
    </div>
</div>
