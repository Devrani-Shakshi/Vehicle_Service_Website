@model ServicePlatform.Models.VehicleModel
@{
    ViewData["Title"] = "Add Vehicle Model";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="VehicleModels">Fleet</a></li>
                    <li class="breadcrumb-item active">Add Model</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary py-4">
                    <h4 class="text-white mb-0 fw-bold">Add New EV Model</h4>
                    <p class="text-white-50 mb-0 small">Add technical specifications for your vehicle fleet</p>
                </div>
                <div class="card-body p-4 p-xl-5">
                    <form asp-action="CreateVehicleModel" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="Name" class="form-label fw-semibold">Model Name</label>
                                <input asp-for="Name" class="form-control form-control-lg bg-light border-0 px-3 rounded-3" placeholder="e.g. Ather 450X" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Type" class="form-label fw-semibold">Vehicle Category</label>
                                <select asp-for="Type" class="form-select form-control-lg bg-light border-0 px-3 rounded-3" asp-items="Html.GetEnumSelectList<ServicePlatform.Models.VehicleType>()"></select>
                                <span asp-validation-for="Type" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ModelNumber" class="form-label fw-semibold">Model Number / SKU</label>
                                <input asp-for="ModelNumber" class="form-control form-control-lg bg-light border-0 px-3 rounded-3" placeholder="e.g. AT-450-GEN3" />
                                <span asp-validation-for="ModelNumber" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ReleaseYear" class="form-label fw-semibold">Launch Year</label>
                                <input asp-for="ReleaseYear" type="number" class="form-control form-control-lg bg-light border-0 px-3 rounded-3" placeholder="2024" value="@DateTime.Now.Year" />
                                <span asp-validation-for="ReleaseYear" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="ImageUrl" class="form-label fw-semibold">Vehicle Illustration URL</label>
                                <input asp-for="ImageUrl" class="form-control form-control-lg bg-light border-0 px-3 rounded-3" placeholder="https://..." />
                                <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Description" class="form-label fw-semibold">Technical Description</label>
                                <textarea asp-for="Description" class="form-control bg-light border-0 px-3 rounded-3" rows="4" placeholder="Mention battery capacity, motor power, and key features..."></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mt-5">
                                <button type="submit" class="btn btn-primary btn-lg w-100 shadow rounded-3 py-3 fw-bold">
                                    Register Model to Fleet
                                </button>
                                <a asp-action="VehicleModels" class="btn btn-link w-100 text-muted mt-2">Cancel and Go Back</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus, .form-select:focus {
        background-color: #fff !important;
        box-shadow: 0 0 0 0.25rem rgba(79, 70, 229, 0.1) !important;
        border: 1px solid #4f46e5 !important;
    }
    .rounded-4 { border-radius: 1.25rem !important; }
</style>
