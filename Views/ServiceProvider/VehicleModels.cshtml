@model IEnumerable<ServicePlatform.Models.VehicleModel>
@{
    ViewData["Title"] = "OEM Fleet Management";
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-gradient-primary mb-1">OEM Fleet Management</h2>
            <p class="text-muted">Manage your EV models and vehicle technical specifications</p>
        </div>
        <a asp-action="CreateVehicleModel" class="btn btn-primary btn-lg shadow-sm">
            <i class="fas fa-plus me-2"></i> Add New Model
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Vehicle Detail</th>
                        <th>Type</th>
                        <th>Model No.</th>
                        <th>Release Year</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="py-4">
                                    <i class="fas fa-car-side fa-3x text-light mb-3"></i>
                                    <p class="text-muted">No vehicle models found in your fleet.</p>
                                    <a asp-action="CreateVehicleModel" class="btn btn-outline-primary btn-sm">Add your first model</a>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm bg-primary-soft rounded-3 me-3 d-flex align-items-center justify-content-center">
                                            <i class="fas fa-charging-station text-primary"></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-semibold">@item.Name</h6>
                                            <small class="text-muted">ID: #@item.Id</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-info-soft text-info rounded-pill px-3">@item.Type</span>
                                </td>
                                <td><code class="text-dark">@item.ModelNumber</code></td>
                                <td>@item.ReleaseYear</td>
                                <td>
                                    @if(item.IsActive)
                                    {
                                        <span class="badge bg-success-soft text-success rounded-pill px-3">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-soft text-danger rounded-pill px-3">Inactive</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="EditVehicleModel" asp-route-id="@item.Id" class="btn btn-icon btn-light btn-sm me-2" title="Edit">
                                            <i class="fas fa-edit text-primary"></i>
                                        </a>
                                        <button onclick="confirmDelete(@item.Id, '@item.Name')" class="btn btn-icon btn-light btn-sm" title="Delete">
                                            <i class="fas fa-trash text-danger"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<form id="deleteForm" asp-action="DeleteVehicleModel" method="post" style="display:none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteId" />
</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(id, name) {
            Swal.fire({
                title: 'Remove Model?',
                text: `Are you sure you want to remove "${name}" from your fleet? This action is permanent.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, remove it!',
                cancelButtonText: 'Cancel',
                background: '#fff',
                customClass: {
                    popup: 'rounded-4 shadow-lg',
                    confirmButton: 'rounded-3 px-4 py-2',
                    cancelButton: 'rounded-3 px-4 py-2'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('deleteId').value = id;
                    document.getElementById('deleteForm').submit();
                }
            });
        }
    </script>
}

<style>
    .text-gradient-primary {
        background: linear-gradient(45deg, #4f46e5, #0ea5e9);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .bg-primary-soft { background-color: rgba(79, 70, 229, 0.1); }
    .bg-info-soft { background-color: rgba(14, 165, 233, 0.1); }
    .bg-success-soft { background-color: rgba(34, 197, 94, 0.1); }
    .bg-danger-soft { background-color: rgba(239, 68, 68, 0.1); }
    .avatar-sm { width: 40px; height: 40px; }
    .btn-icon { width: 32px; height: 32px; padding: 0; display: inline-flex; align-items: center; justify-content: center; border-radius: 8px; transition: all 0.2s; }
    .btn-icon:hover { transform: translateY(-2px); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
    .rounded-4 { border-radius: 1rem !important; }
</style>
