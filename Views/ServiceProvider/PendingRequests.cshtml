@model IEnumerable<ServicePlatform.Models.ServiceRequest>
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Pending Requests"; }

<div class="data-card animate-fadeInUp">
    <div class="data-card-header"><h5><i class="fas fa-clock" style="color:var(--accent);margin-right:8px;"></i>Pending Service Requests</h5></div>
    <table class="table-custom">
        <thead><tr><th>Request</th><th>User</th><th>Type</th><th>Category</th><th>Location</th><th>Date</th><th>Actions</th></tr></thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td style="font-weight:600;">@r.Title</td>
                    <td>@r.User.FullName</td>
                    <td><span class="badge-custom badge-@(r.RequestType.ToString().ToLower() == "urgent" ? "danger" : "primary")">@r.RequestType</span></td>
                    <td>@(r.Category ?? "—")</td>
                    <td>
                        @if (r.Latitude.HasValue) { <a href="/ServiceProvider/ViewLocation/@r.Id" class="btn-outline-custom" style="padding:4px 10px;font-size:0.75rem;"><i class="fas fa-map"></i></a> }
                        else { <span style="color:var(--text-muted);">—</span> }
                    </td>
                    <td style="font-size:0.8rem;color:var(--text-muted);">@r.CreatedAt.ToString("MMM dd")</td>
                    <td style="display:flex;gap:6px;">
                        <form asp-action="AcceptRequest" method="post"><input type="hidden" name="id" value="@r.Id" />@Html.AntiForgeryToken()<button class="btn-success-custom" style="padding:6px 14px;font-size:0.8rem;"><i class="fas fa-check"></i> Accept</button></form>
                        <form asp-action="RejectRequest" method="post"><input type="hidden" name="id" value="@r.Id" />@Html.AntiForgeryToken()<button class="btn-danger-custom" style="padding:6px 14px;font-size:0.8rem;"><i class="fas fa-times"></i></button></form>
                    </td>
                </tr>
            }
            @if (!Model.Any()) { <tr><td colspan="7" class="empty-state"><i class="fas fa-inbox"></i><p>No pending requests</p></td></tr> }
        </tbody>
    </table>
</div>
