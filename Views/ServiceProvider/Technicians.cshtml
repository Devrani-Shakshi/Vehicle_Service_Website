@model IEnumerable<ServicePlatform.Models.SubTechnician>
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Technicians"; }

<div class="data-card animate-fadeInUp">
    <div class="data-card-header">
        <h5><i class="fas fa-users-cog" style="color:var(--primary-light);margin-right:8px;"></i>Sub-Technicians</h5>
        <a href="/ServiceProvider/AddTechnician" class="btn-primary-custom" style="padding:8px 20px;font-size:0.85rem;"><i class="fas fa-plus"></i> Add Technician</a>
    </div>
    <table class="table-custom">
        <thead><tr><th>Name</th><th>Mobile</th><th>Specialization</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td style="font-weight:600;">@t.Name</td>
                    <td>@(t.Mobile ?? "—")</td>
                    <td>@(t.Specialization ?? "General")</td>
                    <td><span class="badge-custom @(t.IsAvailable ? "badge-completed" : "badge-rejected")">@(t.IsAvailable ? "Available" : "Unavailable")</span></td>
                    <td>
                        <form asp-action="ToggleTechAvailability" method="post" style="display:inline;">
                            <input type="hidden" name="id" value="@t.Id" />@Html.AntiForgeryToken()
                            <button type="submit" class="btn-outline-custom" style="padding:6px 14px;font-size:0.8rem;"><i class="fas fa-toggle-on"></i> Toggle</button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Any()) { <tr><td colspan="5" class="empty-state"><i class="fas fa-user-plus"></i><h5>No technicians</h5><p>Add your workshop staff</p></td></tr> }
        </tbody>
    </table>
</div>
