@model ServicePlatform.Models.VehicleModel
@{
    ViewData["Title"] = "Update Model";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="VehicleModels">Fleet</a></li>
                    <li class="breadcrumb-item active">Edit @Model.Name</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary py-4">
                    <h4 class="text-white mb-0 fw-bold">Update Technical Specs</h4>
                    <p class="text-white-50 mb-0 small">Editing data for ID: #@Model.Id</p>
                </div>
                <div class="card-body p-4 p-xl-5">
                    <form asp-action="EditVehicleModel" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ServiceProviderId" />

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="Name" class="form-label fw-semibold">Model Name</label>
                                <input asp-for="Name" class="form-control form-control-lg bg-light border-0 px-3 rounded-3" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Type" class="form-label fw-semibold">Vehicle Category</label>
                                <select asp-for="Type" class="form-select form-control-lg bg-light border-0 px-3 rounded-3" asp-items="Html.GetEnumSelectList<ServicePlatform.Models.VehicleType>()"></select>
                                <span asp-validation-for="Type" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ModelNumber" class="form-label fw-semibold">Model Number / SKU</label>
                                <input asp-for="ModelNumber" class="form-control form-control-lg bg-light border-0 px-3 rounded-3" />
                                <span asp-validation-for="ModelNumber" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ReleaseYear" class="form-label fw-semibold">Launch Year</label>
                                <input asp-for="ReleaseYear" type="number" class="form-control form-control-lg bg-light border-0 px-3 rounded-3" />
                                <span asp-validation-for="ReleaseYear" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <div class="form-check form-switch p-3 bg-light rounded-3">
                                    <input class="form-check-input ms-0 me-2" type="checkbox" asp-for="IsActive">
                                    <label class="form-check-label fw-semibold" asp-for="IsActive">Available for Service Selection</label>
                                </div>
                            </div>

                            <div class="col-12">
                                <label asp-for="ImageUrl" class="form-label fw-semibold">Vehicle Illustration URL</label>
                                <input asp-for="ImageUrl" class="form-control form-control-lg bg-light border-0 px-3 rounded-3" />
                                <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Description" class="form-label fw-semibold">Technical Description</label>
                                <textarea asp-for="Description" class="form-control bg-light border-0 px-3 rounded-3" rows="4"></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mt-5">
                                <button type="submit" class="btn btn-primary btn-lg w-100 shadow rounded-3 py-3 fw-bold">
                                    Save Technical Updates
                                </button>
                                <a asp-action="VehicleModels" class="btn btn-link w-100 text-muted mt-2">Discard Changes</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus, .form-select:focus {
        background-color: #fff !important;
        box-shadow: 0 0 0 0.25rem rgba(79, 70, 229, 0.1) !important;
        border: 1px solid #4f46e5 !important;
    }
    .rounded-4 { border-radius: 1.25rem !important; }
</style>
