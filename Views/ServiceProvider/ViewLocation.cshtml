@model ServicePlatform.Models.ServiceRequest
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Service Location"; }

<div class="data-card animate-fadeInUp">
    <div class="data-card-header">
        <h5><i class="fas fa-map-marked-alt" style="color:var(--danger);margin-right:8px;"></i>@Model.Title - Location</h5>
        <a href="/ServiceProvider" class="btn-outline-custom" style="padding:6px 14px;font-size:0.85rem;"><i class="fas fa-arrow-left"></i> Back</a>
    </div>
    <div class="data-card-body" style="padding:0;">
        <div style="padding:1rem 1.5rem;display:flex;gap:2rem;flex-wrap:wrap;">
            <div><strong style="color:var(--text-muted);font-size:0.8rem;">USER</strong><p>@Model.User.FullName</p></div>
            <div><strong style="color:var(--text-muted);font-size:0.8rem;">TYPE</strong><p>@Model.RequestType</p></div>
            <div><strong style="color:var(--text-muted);font-size:0.8rem;">ADDRESS</strong><p>@(Model.LocationAddress ?? "Not specified")</p></div>
        </div>
        <div id="serviceMap" style="width:100%;height:500px;"></div>
    </div>
</div>

@section Styles { <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" /> }
@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        var lat = @(Model.Latitude ?? 19.076090);
        var lng = @(Model.Longitude ?? 72.877426);
        var map = L.map('serviceMap').setView([lat, lng], 14);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap contributors' }).addTo(map);
        var marker = L.marker([lat, lng]).addTo(map);
        marker.bindPopup('<strong>@Model.Title</strong><br/>Requested by: @Model.User.FullName<br/>@(Model.LocationAddress ?? "")').openPopup();
        L.circle([lat, lng], { color: '#6366f1', fillColor: '#6366f1', fillOpacity: 0.1, radius: 500 }).addTo(map);
    </script>
}
