@model IEnumerable<ServicePlatform.Models.ServiceRequest>
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Completed Requests"; }

<div class="data-card animate-fadeInUp">
    <div class="data-card-header"><h5><i class="fas fa-check-circle" style="color:var(--success);margin-right:8px;"></i>Completed Requests</h5></div>
    <table class="table-custom">
        <thead><tr><th>Request</th><th>User</th><th>Completed</th></tr></thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td style="font-weight:600;">@r.Title</td>
                    <td>@r.User.FullName</td>
                    <td style="font-size:0.8rem;color:var(--text-muted);">@r.CompletedAt?.ToString("MMM dd, yyyy")</td>
                </tr>
            }
            @if (!Model.Any()) { <tr><td colspan="3" class="empty-state"><p>No completed requests</p></td></tr> }
        </tbody>
    </table>
</div>
