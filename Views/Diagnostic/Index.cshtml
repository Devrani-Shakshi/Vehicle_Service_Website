@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "AI Troubleshooter"; }

<div style="width: 100%; max-width: 800px; margin: 0 auto; padding-bottom: 2rem;">
    <div class="data-card animate-fadeInUp">
        <div class="data-card-header text-center" style="display:block; padding:2.5rem 1.5rem;">
            <div style="background:var(--primary-gradient); width:60px; height:60px; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1rem; color:white; font-size:1.5rem; box-shadow:0 10px 20px rgba(99,102,241,0.3);">
                <i class="fas fa-robot"></i>
            </div>
            <h4 style="margin:0;">EV AI Diagnostic Bot</h4>
            <p style="color:var(--text-muted); margin-top:0.5rem; font-size:0.9rem;">I'll help you diagnose your vehicle issues in seconds.</p>
        </div>
        
        <div class="data-card-body" style="padding:2rem;">
            <div id="diagnosticSteps">
                <!-- Step 1: Issue Selection -->
                <div id="step1" class="diag-step active">
                    <h5 style="margin-bottom:1.5rem; font-weight:700;">What seems to be the problem?</h5>
                    <div class="diag-options">
                        <button onclick="nextStep('battery')" class="diag-opt-btn"><i class="fas fa-battery-half"></i> Battery / Charging</button>
                        <button onclick="nextStep('motor')" class="diag-opt-btn"><i class="fas fa-cog"></i> Motor / Acceleration</button>
                        <button onclick="nextStep('range')" class="diag-opt-btn"><i class="fas fa-road"></i> Range / Efficiency</button>
                        <button onclick="nextStep('electronics')" class="diag-opt-btn"><i class="fas fa-microchip"></i> Electronics / Dashboard</button>
                        <button onclick="nextStep('brakes')" class="diag-opt-btn"><i class="fas fa-stop-circle"></i> Brakes / Suspension</button>
                        <button onclick="nextStep('sound')" class="diag-opt-btn"><i class="fas fa-volume-up"></i> Unusual Sound</button>
                        <button onclick="nextStep('tyres')" class="diag-opt-btn"><i class="fas fa-circle"></i> Tyres / Wheels</button>
                        <button onclick="nextStep('software')" class="diag-opt-btn"><i class="fas fa-laptop-code"></i> Software / Firmware</button>
                        <button onclick="showResult('unknown')" class="diag-opt-btn"><i class="fas fa-question-circle"></i> Other / Not Listed</button>
                    </div>
                </div>

                <!-- Step 2: Battery Details -->
                <div id="step_battery" class="diag-step">
                    <h5 style="margin-bottom:1.5rem; font-weight:700;">Tell me more about the battery issue:</h5>
                    <div class="diag-options">
                        <button onclick="showResult('battery_slow')" class="diag-opt-btn">Charging very slow</button>
                        <button onclick="showResult('battery_not_charging')" class="diag-opt-btn">Vehicle not charging at all</button>
                        <button onclick="showResult('battery_heat')" class="diag-opt-btn">Battery area is overheating</button>
                        <button onclick="showResult('unknown')" class="diag-opt-btn">Something else</button>
                    </div>
                </div>

                <!-- Step 2: Motor Details -->
                <div id="step_motor" class="diag-step">
                    <h5 style="margin-bottom:1.5rem; font-weight:700;">What's happening with the motor?</h5>
                    <div class="diag-options">
                        <button onclick="showResult('motor_noise')" class="diag-opt-btn">Making strange grinding noises</button>
                        <button onclick="showResult('motor_loss')" class="diag-opt-btn">Sudden loss of power</button>
                        <button onclick="showResult('motor_vibration')" class="diag-opt-btn">Unusual vibrations</button>
                        <button onclick="showResult('unknown')" class="diag-opt-btn">Other motor issue</button>
                    </div>
                </div>

                <!-- Step 2: Range Details -->
                <div id="step_range" class="diag-step">
                    <h5 style="margin-bottom:1.5rem; font-weight:700;">Range and Efficiency Issues:</h5>
                    <div class="diag-options">
                        <button onclick="showResult('range_drop')" class="diag-opt-btn">Sudden drop in range</button>
                        <button onclick="showResult('range_display')" class="diag-opt-btn">Range display flickering</button>
                        <button onclick="showResult('range_regen')" class="diag-opt-btn">Regen braking not working</button>
                        <button onclick="showResult('unknown')" class="diag-opt-btn">General efficiency issue</button>
                    </div>
                </div>

                <!-- Step 2: Electronics Details -->
                <div id="step_electronics" class="diag-step">
                    <h5 style="margin-bottom:1.5rem; font-weight:700;">Electronics and Dashboard:</h5>
                    <div class="diag-options">
                        <button onclick="showResult('elec_screen')" class="diag-opt-btn">Touchscreen unresponsive</button>
                        <button onclick="showResult('elec_lights')" class="diag-opt-btn">External lights flickering</button>
                        <button onclick="showResult('elec_sensor')" class="diag-opt-btn">Sensor warning on dashboard</button>
                        <button onclick="showResult('elec_ac')" class="diag-opt-btn">AC / Heater not working</button>
                        <button onclick="showResult('unknown')" class="diag-opt-btn">Other electronics issue</button>
                    </div>
                </div>

                <!-- Step 2: Brakes / Suspension -->
                <div id="step_brakes" class="diag-step">
                    <h5 style="margin-bottom:1.5rem; font-weight:700;">Brake & Suspension Concerns:</h5>
                    <div class="diag-options">
                        <button onclick="showResult('brake_squeal')" class="diag-opt-btn">Brakes squealing loudly</button>
                        <button onclick="showResult('brake_soft')" class="diag-opt-btn">Brake pedal feels soft/spongy</button>
                        <button onclick="showResult('suspension_bump')" class="diag-opt-btn">Hard bumps / uneven ride</button>
                        <button onclick="showResult('unknown')" class="diag-opt-btn">Other brake issue</button>
                    </div>
                </div>

                <!-- Step 2: Unusual Sound -->
                <div id="step_sound" class="diag-step">
                    <h5 style="margin-bottom:1.5rem; font-weight:700;">Describe the sound:</h5>
                    <div class="diag-options">
                        <button onclick="showResult('sound_whirr')" class="diag-opt-btn">High-pitched whirring</button>
                        <button onclick="showResult('sound_click')" class="diag-opt-btn">Clicking when turning</button>
                        <button onclick="showResult('sound_hum')" class="diag-opt-btn">Humming at high speed</button>
                        <button onclick="showResult('motor_noise')" class="diag-opt-btn">Grinding noise</button>
                        <button onclick="showResult('unknown')" class="diag-opt-btn">Other sound</button>
                    </div>
                </div>

                <!-- Step 2: Tyres -->
                <div id="step_tyres" class="diag-step">
                    <h5 style="margin-bottom:1.5rem; font-weight:700;">Tyre & Wheel Issues:</h5>
                    <div class="diag-options">
                        <button onclick="showResult('tyre_pressure')" class="diag-opt-btn">TPMS warning light on</button>
                        <button onclick="showResult('tyre_wear')" class="diag-opt-btn">Uneven tyre wear</button>
                        <button onclick="showResult('tyre_vibration')" class="diag-opt-btn">Steering wheel vibration</button>
                        <button onclick="showResult('unknown')" class="diag-opt-btn">Other tyre issue</button>
                    </div>
                </div>

                <!-- Step 2: Software -->
                <div id="step_software" class="diag-step">
                    <h5 style="margin-bottom:1.5rem; font-weight:700;">Software & Firmware:</h5>
                    <div class="diag-options">
                        <button onclick="showResult('sw_update')" class="diag-opt-btn">OTA update failed</button>
                        <button onclick="showResult('sw_error')" class="diag-opt-btn">Error code on dashboard</button>
                        <button onclick="showResult('sw_freeze')" class="diag-opt-btn">System freezes randomly</button>
                        <button onclick="showResult('sw_app')" class="diag-opt-btn">Mobile app not connecting</button>
                        <button onclick="showResult('unknown')" class="diag-opt-btn">Other software issue</button>
                    </div>
                </div>

                <!-- Result Section -->
                <div id="diagResult" class="diag-step">
                    <div style="background:rgba(16, 185, 129, 0.05); border:1px solid var(--success); border-radius:var(--radius-lg); padding:2rem; text-align:center;">
                        <i class="fas fa-check-circle" style="color:var(--success); font-size:3rem; margin-bottom:1rem;"></i>
                        <h4 id="resultTitle" style="color:var(--text-primary);">Diagnosis Complete</h4>
                        <p id="resultDesc" style="color:var(--text-secondary); margin-bottom:1.5rem;">Based on your inputs, here's what we found...</p>
                        
                        <div id="diyBox" style="background:var(--bg-card); border-radius:var(--radius-md); padding:1rem; margin-bottom:1.5rem; text-align:left;">
                            <strong style="color:var(--primary-light); font-size:0.8rem; display:block; margin-bottom:0.5rem;">DIY FIX SUGGESTION</strong>
                            <p id="diyText" style="font-size:0.9rem; margin:0;"></p>
                        </div>

                        <div style="display:flex; gap:1rem; justify-content:center;">
                            <a href="/UserDashboard/CreateRequest" class="btn-primary-custom" id="bookAction">Book Professional Repair</a>
                            <button onclick="resetDiag()" class="btn-outline-custom">Start Over</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .diag-step { display: none; }
        .diag-step.active { display: block; animation: fadeInUp 0.4s ease; }
        .diag-options { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
        .diag-opt-btn { 
            background: var(--bg-primary); border: 1px solid var(--border-color); 
            padding: 1.5rem; border-radius: var(--radius-md); color: var(--text-primary);
            font-weight: 600; text-align: left; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex; align-items: center; gap: 12px;
        }
        .diag-opt-btn i { font-size: 1.2rem; color: var(--primary-light); }
        .diag-opt-btn:hover { 
            border-color: var(--primary); background: var(--bg-card); 
            transform: translateY(-3px); box-shadow: var(--shadow-md);
        }
    </style>
}

@section Scripts {
    <script>
        const data = {
            'battery_slow': {
                title: "Charging Optimization Needed",
                desc: "Your BMS (Battery Management System) might be throttling speeds due to temperature or grid load.",
                diy: "Check if the charger cable is firmly connected. Avoid charging immediately after a long ride; let the battery cool for 30 minutes.",
                category: "Battery Service"
            },
            'battery_not_charging': {
                title: "Inlet or Fuse Fault",
                desc: "The connection between your charging port and the battery pack might be broken.",
                diy: "Inspect the charging pins for any debris or burn marks. If clear, it's likely an internal fuse blown which requires a technician.",
                category: "Battery Service"
            },
            'motor_noise': {
                title: "Bearing or Gear Wear",
                desc: "Strange noises usually indicate mechanical friction in the motor assembly or reduction gear.",
                diy: "Do not attempt a DIY fix for motor internals. Grinding noises can lead to total motor failure if not addressed.",
                category: "Motor Repair"
            },
            'range_drop': {
                title: "Battery Cell Imbalance",
                desc: "A sudden drop in range usually means some battery cells are discharging faster than others.",
                diy: "Charge to 100% and leave it plugged in for 2 extra hours to allow the BMS to balance the cells.",
                category: "Battery Service"
            },
            'elec_screen': {
                title: "Software System Glitch",
                desc: "The main head unit might be overwhelmed by background processes or a memory leak.",
                diy: "Perform a hard reset by holding the power button and brake together for 10 seconds (check manual).",
                category: "Electronics"
            },
            'battery_heat': {
                title: "Thermal Management Alert",
                desc: "The cooling system for the battery pack may be failing. This is a CRITICAL issue — stop driving immediately.",
                diy: "Turn off AC, park in shade, and do NOT charge until inspected. Check coolant level if accessible.",
                category: "Battery Service"
            },
            'motor_loss': {
                title: "Inverter / Controller Fault",
                desc: "Sudden power loss is often related to the motor controller or inverter overheating.",
                diy: "Pull over safely. Turn off the vehicle for 15 minutes to let the inverter cool. If it recurs, do not drive.",
                category: "Motor Repair"
            },
            'motor_vibration': {
                title: "Motor Mount or CV Joint Wear",
                desc: "Unusual vibrations can indicate worn motor mounts or a damaged CV joint.",
                diy: "Check under the car for any loose components. Do not ignore vibrations — they worsen quickly.",
                category: "Motor Repair"
            },
            'range_display': {
                title: "BMS Calibration Error",
                desc: "The estimated range display relies on battery cell voltage readings. A miscalibration shows wrong data.",
                diy: "Fully discharge to 10%, then charge to 100% without interruption. This recalibrates the BMS.",
                category: "Battery Service"
            },
            'range_regen': {
                title: "Regenerative Braking Fault",
                desc: "Regen braking failure can be caused by a full battery, cold weather, or an ABS sensor issue.",
                diy: "Check if the battery is near 100% (regen disables when full). In cold weather, drive slowly for 5 min first.",
                category: "Motor Repair"
            },
            'elec_lights': {
                title: "12V Auxiliary Battery Issue",
                desc: "Flickering lights usually mean the 12V accessory battery is weak, not the main traction battery.",
                diy: "Check the 12V battery voltage with a multimeter. Replace if below 11.5V — it's a standard car battery.",
                category: "Electronics"
            },
            'elec_sensor': {
                title: "Sensor Calibration Needed",
                desc: "Dashboard warnings can be triggered by dirty or misaligned sensors (parking, speed, or temperature).",
                diy: "Clean all visible sensor lenses. If warning persists after a restart, a professional diagnostic scan is needed.",
                category: "Electronics"
            },
            'elec_ac': {
                title: "HVAC Compressor or Relay Fault",
                desc: "EV AC systems use electric compressors. Failure could be a relay, fuse, or refrigerant leak.",
                diy: "Check fuse box for blown AC fuse. If intact, the compressor likely needs professional attention.",
                category: "Electronics"
            },
            'brake_squeal': {
                title: "Brake Pad Wear",
                desc: "EV brake pads last longer due to regen braking, but they still wear out. Squealing means replacement time.",
                diy: "Inspect pad thickness visually through the wheel spokes. Less than 3mm? Replace immediately.",
                category: "Brake Service"
            },
            'brake_soft': {
                title: "Brake Fluid or Hydraulic Issue",
                desc: "A spongy brake pedal indicates air in the brake lines or low fluid level.",
                diy: "Check brake fluid reservoir level. Top up if low. If pedal remains soft, do NOT drive — get it towed.",
                category: "Brake Service"
            },
            'suspension_bump': {
                title: "Shock Absorber Wear",
                desc: "EVs are heavier due to batteries, which puts extra stress on suspension components.",
                diy: "Push down each corner of the car — if it bounces more than once, shocks are likely worn.",
                category: "Suspension"
            },
            'sound_whirr': {
                title: "Normal EV Motor Sound (Likely Safe)",
                desc: "A faint high-pitched whirring is the normal sound of an electric motor at speed. This is expected.",
                diy: "If the pitch hasn't changed and there's no vibration, this is just your motor working. No action needed.",
                category: "General Servicing"
            },
            'sound_click': {
                title: "CV Joint or Steering Rack Issue",
                desc: "Clicking during turns is a classic sign of a worn CV joint boot that has lost its grease.",
                diy: "Inspect the rubber boots on front axle shafts. If torn or leaking grease, get it replaced ASAP.",
                category: "Suspension"
            },
            'sound_hum': {
                title: "Wheel Bearing Wear",
                desc: "A humming sound that gets louder with speed usually comes from a failing wheel bearing.",
                diy: "Jack up the car and try to wiggle each wheel. Any play means the bearing needs replacement.",
                category: "Suspension"
            },
            'tyre_pressure': {
                title: "TPMS Sensor Alert",
                desc: "Tyre Pressure Monitoring System detected low pressure in one or more tyres.",
                diy: "Check all four tyres with a gauge. Inflate to the recommended PSI on the driver's door sticker.",
                category: "Tyre Service"
            },
            'tyre_wear': {
                title: "Alignment or Rotation Needed",
                desc: "EV instant torque accelerates front tyre wear. Uneven wear means alignment is off.",
                diy: "Rotate tyres every 8,000 km. Book a wheel alignment if inner/outer edges are wearing faster.",
                category: "Tyre Service"
            },
            'tyre_vibration': {
                title: "Wheel Balancing Required",
                desc: "Steering vibration at highway speeds indicates unbalanced wheels or a bent rim.",
                diy: "Get wheels balanced at any tyre shop. If vibration remains, a rim may be damaged.",
                category: "Tyre Service"
            },
            'sw_update': {
                title: "OTA Update Recovery",
                desc: "A failed over-the-air update can leave the car in a partial firmware state.",
                diy: "Ensure stable WiFi, charge battery above 50%, and retry from Settings > System Updates. If stuck, contact support.",
                category: "Software"
            },
            'sw_error': {
                title: "Diagnostic Trouble Code (DTC)",
                desc: "Error codes on the dashboard point to specific component faults logged by the ECU.",
                diy: "Note the exact code (e.g., P0A80). Search it online for your model. A professional OBD-II scan gives full details.",
                category: "Software"
            },
            'sw_freeze': {
                title: "Infotainment Memory Overload",
                desc: "Random system freezes are usually caused by too many background apps or a corrupted cache.",
                diy: "Go to Settings > Storage > Clear Cache. If that fails, perform a factory reset of the head unit only.",
                category: "Software"
            },
            'sw_app': {
                title: "Bluetooth / Telematics Module Issue",
                desc: "Phone connectivity issues can be Bluetooth, WiFi, or the car's telematics unit.",
                diy: "Unpair and re-pair the phone. Toggle airplane mode. If still failing, restart the car's infotainment.",
                category: "Software"
            }
        };

        function nextStep(stepId) {
            const target = document.getElementById('step_' + stepId);
            if (!target) {
                console.error('Target step not found: step_' + stepId);
                // Fallback: stay on current or show result as fallback
                return;
            }
            document.querySelectorAll('.diag-step').forEach(s => s.classList.remove('active'));
            target.classList.add('active');
        }

        function showResult(key) {
            const res = data[key] || { 
                title: "Diagnosis Inconclusive", 
                desc: "We couldn't pinpoint the exact cause based on the automated checks. A manual inspection by our senior technicians is highly recommended.", 
                diy: "Safely park your vehicle and avoid long trips until a professional looks at it. Check if any dashboard error codes are visible.", 
                category: "General Servicing",
                isUnknown: true
            };
            
            document.getElementById('resultTitle').innerText = res.title;
            document.getElementById('resultDesc').innerText = res.desc;
            document.getElementById('diyText').innerText = res.diy;
            
            const resultBox = document.querySelector('#diagResult div');
            if (res.isUnknown) {
                resultBox.style.borderColor = "var(--primary)";
                resultBox.querySelector('i').className = "fas fa-user-md";
                resultBox.querySelector('i').style.color = "var(--primary)";
                document.getElementById('bookAction').innerText = "Talk to a Manual Support Specialist";
            } else {
                resultBox.style.borderColor = "var(--success)";
                resultBox.querySelector('i').className = "fas fa-check-circle";
                resultBox.querySelector('i').style.color = "var(--success)";
                document.getElementById('bookAction').innerText = "Book Professional Repair";
            }

            // Pre-fill booking link with category
            document.getElementById('bookAction').href = `/UserDashboard/CreateRequest?title=${encodeURIComponent(res.title)}&category=${encodeURIComponent(res.category)}&notes=${encodeURIComponent("Automated Diagnosis: " + res.desc)}`;

            document.querySelectorAll('.diag-step').forEach(s => s.classList.remove('active'));
            document.getElementById('diagResult').classList.add('active');
        }

        function resetDiag() {
            document.querySelectorAll('.diag-step').forEach(s => s.classList.remove('active'));
            document.getElementById('step1').classList.add('active');
        }
    </script>
}
