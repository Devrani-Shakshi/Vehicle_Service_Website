@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}

<div class="hero-section">
    <div class="hero-content">
        <div class="animate__animated animate__fadeInDown">
            <span style="background: var(--primary-gradient); padding: 6px 20px; border-radius: 50px; font-size: 0.85rem; font-weight: 600; display: inline-block; margin-bottom: 1.5rem;">
                <i class="fas fa-rocket"></i> Enterprise Service Management Platform
            </span>
        </div>
        <h1 class="animate__animated animate__fadeInUp">Integrated Service<br/>Management &amp; Shopping</h1>
        <p class="animate__animated animate__fadeInUp animate__delay-1s">
            A complete platform connecting users, service providers, and shopkeepers.
            Book services, track requests, shop products — all in one place.
        </p>
        <div class="animate__animated animate__fadeInUp animate__delay-1s" style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
            <a href="/Account/Register" class="btn-primary-custom">
                <i class="fas fa-user-plus"></i> Get Started
            </a>
            <a href="/Account/Login" class="btn-outline-custom">
                <i class="fas fa-sign-in-alt"></i> Sign In
            </a>
        </div>

        <!-- Feature highlights -->
        <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(200px, 1fr));gap:1.5rem;margin-top:4rem;" class="animate__animated animate__fadeInUp animate__delay-2s">
            <div style="background:var(--glass-bg);backdrop-filter:blur(20px);border:1px solid var(--glass-border);border-radius:var(--radius-lg);padding:1.5rem;text-align:center;">
                <i class="fas fa-wrench" style="font-size:2rem;color:var(--primary-light);margin-bottom:0.75rem;display:block;"></i>
                <h6 style="font-weight:700;margin-bottom:0.25rem;">Service Requests</h6>
                <p style="font-size:0.8rem;color:var(--text-muted);margin:0;">Book and track services with live GPS tracking</p>
            </div>
            <div style="background:var(--glass-bg);backdrop-filter:blur(20px);border:1px solid var(--glass-border);border-radius:var(--radius-lg);padding:1.5rem;text-align:center;">
                <i class="fas fa-store" style="font-size:2rem;color:var(--success);margin-bottom:0.75rem;display:block;"></i>
                <h6 style="font-weight:700;margin-bottom:0.25rem;">Online Shopping</h6>
                <p style="font-size:0.8rem;color:var(--text-muted);margin:0;">Browse products, add to cart, and pay securely</p>
            </div>
            <div style="background:var(--glass-bg);backdrop-filter:blur(20px);border:1px solid var(--glass-border);border-radius:var(--radius-lg);padding:1.5rem;text-align:center;">
                <i class="fas fa-bell" style="font-size:2rem;color:var(--accent);margin-bottom:0.75rem;display:block;"></i>
                <h6 style="font-weight:700;margin-bottom:0.25rem;">Real-Time Updates</h6>
                <p style="font-size:0.8rem;color:var(--text-muted);margin:0;">Instant notifications via SignalR technology</p>
            </div>
            <div style="background:var(--glass-bg);backdrop-filter:blur(20px);border:1px solid var(--glass-border);border-radius:var(--radius-lg);padding:1.5rem;text-align:center;">
                <i class="fas fa-map-marked-alt" style="font-size:2rem;color:var(--danger);margin-bottom:0.75rem;display:block;"></i>
                <h6 style="font-weight:700;margin-bottom:0.25rem;">Live Tracking</h6>
                <p style="font-size:0.8rem;color:var(--text-muted);margin:0;">OpenStreetMap integration with Leaflet.js</p>
            </div>
        </div>
    </div>

    <!-- Floating orbs decoration -->
    <div style="position:absolute;top:10%;right:10%;width:300px;height:300px;background:radial-gradient(circle,rgba(99,102,241,0.2),transparent);border-radius:50%;filter:blur(60px);animation:float 6s ease-in-out infinite;"></div>
    <div style="position:absolute;bottom:10%;left:10%;width:250px;height:250px;background:radial-gradient(circle,rgba(139,92,246,0.15),transparent);border-radius:50%;filter:blur(60px);animation:float 8s ease-in-out infinite reverse;"></div>
</div>

<style>
@@keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-30px); }
}
</style>
