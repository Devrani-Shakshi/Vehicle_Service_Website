@{
    ViewData["Title"] = "The Unified EV Ecosystem";
    Layout = "_Layout";
}

<div class="hero-section" style="background: url('/ev_ecosystem_hero_1775644123440.png') no-repeat center center/cover; position: relative; min-height: 100vh; display: flex; align-items: center; justify-content: center; overflow: hidden;">
    <!-- Dark overlay for better text readability -->
    <div style="position: absolute; top:0; left:0; width:100%; height:100%; background: linear-gradient(135deg, rgba(15, 23, 42, 0.95) 0%, rgba(15, 23, 42, 0.7) 100%); z-index: 1;"></div>

    <div class="hero-content" style="position: relative; z-index: 2; max-width: 1200px; padding: 2rem;">
        <div class="animate__animated animate__fadeInDown">
            <span style="background: var(--primary-gradient); padding: 8px 24px; border-radius: 50px; font-size: 0.9rem; font-weight: 700; display: inline-block; margin-bottom: 2rem; box-shadow: 0 4px 15px rgba(99, 102, 241, 0.4); text-transform: uppercase; letter-spacing: 1px;">
                <i class="fas fa-bolt"></i> Next-Gen EV Infrastructure
            </span>
        </div>
        <h1 class="animate__animated animate__fadeInUp" style="font-size: clamp(2.5rem, 5vw, 4.5rem); font-weight: 900; line-height: 1.1; margin-bottom: 1.5rem; letter-spacing: -1px;">
            The Ultimate <span style="background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Electric Vehicle</span><br/>Service Ecosystem
        </h1>
        <p class="animate__animated animate__fadeInUp animate__delay-1s" style="font-size: 1.25rem; color: #cbd5e1; max-width: 700px; margin: 0 auto 3rem; line-height: 1.6;">
            A specialized 4-way platform connecting EV Owners with Manufacturers like <span class="fw-bold text-white">Tata Motors</span> & <span class="fw-bold text-white">BYD</span>, Certified Service Providers, and Specialized EV Spare Part Vendors.
        </p>
        
        <div class="animate__animated animate__fadeInUp animate__delay-1s" style="display:flex;gap:20px;justify-content:center;flex-wrap:wrap;">
            <a href="/Account/Register" class="btn-primary-custom" style="padding: 16px 40px; font-size: 1.1rem; border-radius: 12px;">
                <i class="fas fa-plug" style="margin-right:8px;"></i> Join the Ecosystem
            </a>
            <a href="/Account/Login" class="btn-outline-custom" style="padding: 16px 40px; font-size: 1.1rem; border-radius: 12px; background: rgba(255,255,255,0.05); backdrop-filter: blur(10px);">
                <i class="fas fa-sign-in-alt" style="margin-right:8px;"></i> Access Dashboard
            </a>
        </div>

        <!-- Role Pillars -->
        <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(240px, 1fr));gap:2rem;margin-top:5rem;" class="animate__animated animate__fadeInUp animate__delay-2s">
            <div class="glass-card">
                <i class="fas fa-user-shield"></i>
                <h6>Admin Panel</h6>
                <p>Full governance of users, providers, and shopkeepers with financial analytics.</p>
            </div>
            <div class="glass-card">
                <i class="fas fa-car-battery"></i>
                <h6>Shopkeeper</h6>
                <p>E-commerce portal exclusively for EV battery kits, motor parts, and accessories.</p>
            </div>
            <div class="glass-card">
                <i class="fas fa-tools"></i>
                <h6>Service Provider</h6>
                <p>Direct manufacturer support (Tata, Ether) for professional tech diagnostics.</p>
            </div>
            <div class="glass-card">
                <i class="fas fa-mobile-alt"></i>
                <h6>User Hub</h6>
                <p>Book breakdown services, track live technician GPS, and purchase genuine parts.</p>
            </div>
        </div>
    </div>
</div>

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        padding: 2rem;
        text-align: center;
        transition: all 0.3s ease;
    }
    .glass-card:hover {
        background: rgba(255, 255, 255, 0.07);
        transform: translateY(-10px);
        border-color: var(--primary-light);
        box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }
    .glass-card i {
        font-size: 2.5rem;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 1.25rem;
        display: block;
    }
    .glass-card h6 {
        font-weight: 800;
        font-size: 1.1rem;
        margin-bottom: 0.75rem;
        color: white;
    }
    .glass-card p {
        font-size: 0.85rem;
        color: #94a3b8;
        margin: 0;
        line-height: 1.5;
    }
</style>
