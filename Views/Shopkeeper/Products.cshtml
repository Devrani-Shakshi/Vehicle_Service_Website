@model IEnumerable<ServicePlatform.Models.Product>
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "My Products"; }

<div class="data-card animate-fadeInUp">
    <div class="data-card-header">
        <h5 style="display:flex;align-items:center;gap:8px;"><i class="fas fa-boxes-stacked" style="color:var(--primary-light);"></i>Products</h5>
        <div style="display:flex;gap:1rem;align-items:center;">
             <input type="text" id="productSearch" class="form-control" placeholder="Search products..." style="width:180px;padding:6px 12px;font-size:0.8rem;" />
             <a href="/Shopkeeper/AddProduct" class="btn-primary-custom" style="padding:8px 20px;font-size:0.85rem;" 
                data-bs-toggle="tooltip" data-bs-title="Create a new product listing"><i class="fas fa-plus"></i> Add Product</a>
        </div>
    </div>
    <table class="table-custom" id="productsTable">
        <thead><tr><th>Image</th><th>Product</th><th>Price</th><th>Category</th><th>Stock</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>
                        <div style="width: 48px; height: 48px; border-radius: 8px; overflow: hidden; background: var(--bg-secondary); border: 1px solid var(--border-color); display: flex; align-items: center; justify-content: center;">
                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                            {
                                <img src="@p.ImageUrl" alt="@p.Name" style="width: 100%; height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <i class="fas fa-box text-muted"></i>
                            }
                        </div>
                    </td>
                    <td style="font-weight:600;">@p.Name</td>
                    <td>
                        @if (p.DiscountPrice.HasValue)
                        {
                            <span style="color:var(--success);font-weight:700;">₹@p.DiscountPrice.Value.ToString("N0")</span>
                            <span style="text-decoration:line-through;color:var(--text-muted);font-size:0.8rem;margin-left:4px;">₹@p.Price.ToString("N0")</span>
                        }
                        else
                        {
                            <span style="color:var(--success);font-weight:700;">₹@p.Price.ToString("N0")</span>
                        }
                    </td>
                    <td>@(p.Category ?? "—")</td>
                    <td><span class="@(p.StockQuantity > 0 ? "" : "badge-custom badge-danger")">@p.StockQuantity</span></td>
                    <td><span class="badge-custom @(p.IsActive ? "badge-completed" : "badge-rejected")">@(p.IsActive ? "Active" : "Inactive")</span></td>
                    <td style="display:flex;gap:6px;">
                        <a href="/Shopkeeper/EditProduct/@p.Id" class="btn-outline-custom" style="padding:6px 14px;font-size:0.8rem;" 
                           data-bs-toggle="tooltip" data-bs-title="Edit product details"><i class="fas fa-edit"></i></a>
                        <form asp-action="DeleteProduct" method="post" style="display:inline;"><input type="hidden" name="id" value="@p.Id" />@Html.AntiForgeryToken()<button type="submit" class="btn-danger-custom" style="padding:6px 14px;font-size:0.8rem;" 
                                data-bs-toggle="tooltip" data-bs-title="Delete this product permanentely" onclick="return confirm('Delete this product?')"><i class="fas fa-trash"></i></button></form>
                    </td>
                </tr>
            }
            @if (!Model.Any()) { <tr><td colspan="6" class="empty-state"><i class="fas fa-box-open"></i><h5>No products</h5><p>Add your first product</p></td></tr> }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            initTableSearch('productSearch', 'productsTable');
        });
    </script>
}
