@model IEnumerable<ServicePlatform.Models.Rating>
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Product Reviews"; }

<div class="data-card animate-fadeInUp">
    <div class="data-card-header"><h5><i class="fas fa-star" style="color:var(--warning);margin-right:8px;"></i>Product Reviews</h5></div>
    <div class="data-card-body" style="padding:1.5rem;">
        @if (Model.Any())
        {
            @foreach (var r in Model)
            {
                <div style="background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:1.25rem;margin-bottom:1rem;">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;">
                        <span style="font-weight:600;">@(r.User?.FullName ?? "Anonymous")</span>
                        <span style="color:var(--warning);">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="fas fa-star@(i <= r.Stars ? "" : "-o")" style="font-size:0.9rem;"></i>
                            }
                            (@r.Stars/5)
                        </span>
                    </div>
                    <p style="color:var(--text-secondary);margin:0;font-size:0.9rem;">@(r.Comment ?? "No comment")</p>
                    <p style="color:var(--text-muted);font-size:0.75rem;margin:0.5rem 0 0;">@r.CreatedAt.ToString("dd MMM yyyy")</p>
                </div>
            }
        }
        else
        {
            <div class="empty-state" style="text-align:center;padding:3rem;"><i class="fas fa-comments" style="font-size:3rem;color:var(--text-muted);margin-bottom:1rem;"></i><h5>No reviews yet</h5><p>Customer reviews will appear here</p></div>
        }
    </div>
</div>
