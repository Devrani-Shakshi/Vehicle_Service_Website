@model IEnumerable<ServicePlatform.Models.Order>
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Customer Orders"; }

<div class="data-card animate-fadeInUp">
    <div class="data-card-header"><h5><i class="fas fa-shopping-bag" style="color:var(--success);margin-right:8px;"></i>Customer Orders</h5></div>
    <table class="table-custom">
        <thead><tr><th>Order #</th><th>Customer</th><th>Items</th><th>Total</th><th>Status</th><th>Date</th><th>Actions</th></tr></thead>
        <tbody>
            @foreach (var o in Model)
            {
                <tr>
                    <td style="font-family:monospace;font-size:0.8rem;">@o.OrderNumber</td>
                    <td>@o.User.FullName</td>
                    <td>@o.OrderItems.Count</td>
                    <td style="font-weight:700;color:var(--success);">₹@o.TotalAmount.ToString("N0")</td>
                    <td><span class="badge-custom badge-@o.Status.ToString().ToLower()">@o.Status</span></td>
                    <td style="font-size:0.8rem;color:var(--text-muted);">@o.CreatedAt.ToString("MMM dd")</td>
                    <td>
                        <form asp-action="UpdateOrderStatus" method="post" style="display:flex;gap:6px;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@o.Id" />
                            <select name="status" class="form-control" style="background:var(--bg-input);border:1px solid var(--border-color);color:var(--text-primary);padding:6px;font-size:0.8rem;border-radius:6px;width:120px;">
                                @foreach (ServicePlatform.Models.OrderStatus s in Enum.GetValues(typeof(ServicePlatform.Models.OrderStatus))) { <option value="@s" selected="@(o.Status == s)">@s</option> }
                            </select>
                            <button class="btn-primary-custom" style="padding:6px 14px;font-size:0.8rem;"><i class="fas fa-sync"></i></button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Any()) { <tr><td colspan="7" class="empty-state"><p>No orders</p></td></tr> }
        </tbody>
    </table>
</div>
