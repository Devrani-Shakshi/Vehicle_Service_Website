@model ServicePlatform.ViewModels.Shop.ProductViewModel
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Add Product"; }

<div style="width: 100%; padding-bottom: 2rem;">
    <div class="data-card animate-fadeInUp">
        <div class="data-card-header"><h5><i class="fas fa-plus-circle" style="color:var(--primary-light);margin-right:8px;"></i>Add New Product</h5></div>
        <div class="data-card-body">
            <form asp-action="AddProduct" method="post">
                @Html.AntiForgeryToken()
                <div class="form-floating-custom"><label asp-for="Name">Product Name</label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" style="color:var(--danger);font-size:0.8rem;"></span></div>
                <div class="form-floating-custom"><label asp-for="Description">Description</label><textarea asp-for="Description" class="form-control" rows="3"></textarea></div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                    <div class="form-floating-custom"><label asp-for="Price">Price (₹)</label><input asp-for="Price" type="number" step="0.01" class="form-control" /><span asp-validation-for="Price" style="color:var(--danger);font-size:0.8rem;"></span></div>
                    <div class="form-floating-custom"><label asp-for="DiscountPrice">Discount Price (₹)</label><input asp-for="DiscountPrice" type="number" step="0.01" class="form-control" /></div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                    <div class="form-floating-custom">
                        <label asp-for="Category">Category</label>
                        <select asp-for="Category" class="form-control">
                            <option value="">Select Category</option>
                            @foreach (var cat in ServicePlatform.Helpers.AppConstants.ProductCategories)
                            {
                                <option value="@cat">@cat</option>
                            }
                        </select>
                    </div>
                    <div class="form-floating-custom"><label asp-for="StockQuantity">Stock Qty</label><input asp-for="StockQuantity" type="number" class="form-control" /></div>
                </div>
                <div class="form-floating-custom"><label asp-for="ImageUrl">Image URL</label><input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" /></div>
                <div class="form-floating-custom"><label asp-for="SKU">SKU</label><input asp-for="SKU" class="form-control" placeholder="Optional product SKU" /></div>
                <button type="submit" class="btn-primary-custom" style="width:100%;justify-content:center;"><i class="fas fa-plus"></i> Add Product</button>
            </form>
        </div>
    </div>
</div>
