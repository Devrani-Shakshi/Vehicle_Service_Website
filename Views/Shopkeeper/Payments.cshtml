@model IEnumerable<ServicePlatform.Models.Payment>
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Payments Received"; }

<div class="data-card animate-fadeInUp">
    <div class="data-card-header" style="display:flex; justify-content:space-between; align-items:center;">
        <h5 style="margin:0;"><i class="fas fa-receipt" style="margin-right:8px; color:var(--success);"></i>Orders & Store Payments</h5>
        <div style="display:flex; gap:12px;">
            <a href="@Url.Action("DownloadReport", new { type = "payments" })" class="btn btn-sm btn-outline-primary"><i class="fas fa-file-download"></i> CSV Report</a>
            <div style="font-size:0.8rem; font-weight:700; color:var(--success);">Total Settled: ₹@Model.Where(p => p.Status == PaymentStatus.Completed).Sum(p => p.Amount).ToString("N0")</div>
        </div>
    </div>
    <div class="data-card-body">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Payment ID</th>
                    <th>Date</th>
                    <th>Customer</th>
                    <th>Order #</th>
                    <th>Gateway</th>
                    <th>Amount</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td style="font-family:monospace;font-size:0.75rem;color:var(--text-muted);">#@p.Id.ToString("000000")</td>
                        <td style="font-size:0.85rem;">@p.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                        <td style="font-weight:600;">@p.User?.FullName</td>
                        <td style="font-family:monospace;color:var(--primary-light);">@p.Order?.OrderNumber</td>
                        <td><span class="badge-custom badge-info">@p.Gateway</span></td>
                        <td style="font-weight:700; color:var(--success);">₹@p.Amount.ToString("N0")</td>
                        <td><span class="badge-custom badge-@p.Status.ToString().ToLower()">@p.Status</span></td>
                    </tr>
                }
                @if (!Model.Any()) {
                    <tr><td colspan="7" class="empty-state">No payment history found yet. Orders will appear here after customer checkout.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
