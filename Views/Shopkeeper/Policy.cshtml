@inject IConfiguration Configuration
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Platform Policies"; var commRate = Configuration.GetValue<int>("GlobalSettings:CommissionRate", 5); }

<div style="width: 100%; padding-bottom: 2rem;">
    <div class="data-card animate-fadeInUp">
        <div class="data-card-header" style="background:var(--primary-gradient); color:white;">
            <h5 style="margin:0;"><i class="fas fa-shield-alt" style="margin-right:8px;"></i>Terms & Policies</h5>
        </div>
        <div class="data-card-body" style="padding:2.5rem;">
            <div class="policy-section" style="margin-bottom:2rem;">
                <h4 style="color:var(--primary-light);margin-bottom:1rem;">1. Introduction</h4>
                <p style="color:var(--text-secondary);line-height:1.7;">Welcome to ServicePlatform EV. These Terms and Conditions govern your use of our platform and services. By accessing or using the platform, you agree to be bound by these terms.</p>
            </div>

            <div class="policy-section" style="margin-bottom:2rem;">
                <h4 style="color:var(--primary-light);margin-bottom:1rem;">2. User Conduct</h4>
                <p style="color:var(--text-secondary);line-height:1.7;">All users (Customers, Service Providers, and Shopkeepers) must maintain a high standard of professionalism. Any fraudulent activity, harassment, or violation of local laws will result in immediate account suspension.</p>
                <ul style="color:var(--text-secondary);line-height:1.7;margin-top:0.5rem;">
                    <li>Accurate information must be provided during registration.</li>
                    <li>Service providers must complete accepted requests professionally.</li>
                    <li>Shopkeepers must ensure product quality and timely shipping.</li>
                </ul>
            </div>

            <div class="policy-section" style="margin-bottom:2rem;">
                <h4 style="color:var(--primary-light);margin-bottom:1rem;">3. Payments & Platform Fees</h4>
                <p style="color:var(--text-secondary);line-height:1.7;">Payments are processed through secure gateways. A platform commission of <strong>@commRate%</strong> applies to all Service Providers and Shopkeepers based on their monthly income. This fee is auto-calculated at the end of each month and must be settled within the billing cycle. Users (customers) are not charged any platform fee.</p>
            </div>

            <div class="policy-section" style="margin-bottom:2rem;">
                <h4 style="color:var(--primary-light);margin-bottom:1rem;">4. Privacy Policy</h4>
                <p style="color:var(--text-secondary);line-height:1.7;">We value your privacy. Your personal data is encrypted and used only for service fulfillment and platform improvement. We never sell your data to third parties.</p>
            </div>

            <div class="policy-section">
                <h4 style="color:var(--primary-light);margin-bottom:1rem;">5. Contact Information</h4>
                <p style="color:var(--text-secondary);line-height:1.7;">For any queries regarding these policies, please contact our legal team at legal@serviceplatform.com.</p>
            </div>

            <div style="margin-top:3rem; padding:1.5rem; background:rgba(99, 102, 241, 0.05); border-radius:var(--radius-sm); border:1px dashed var(--primary-light); text-align:center;">
                <p style="margin:0; font-size:0.9rem; color:var(--text-muted);">Last Updated: April 2026 | Version 2.0.5</p>
            </div>
        </div>
    </div>
</div>
