@{
    ViewData["Title"] = "Error";
}

<div class="auth-page">
    <div class="auth-card text-center">
        <i class="fas fa-exclamation-triangle" style="font-size: 4rem; color: var(--warning); margin-bottom: 1.5rem;"></i>
        <h2 style="-webkit-text-fill-color: var(--text-primary);">Something Went Wrong</h2>
        <p class="subtitle">@(ViewContext.HttpContext.Request.Query["message"].FirstOrDefault() ?? "An unexpected error occurred.")</p>
        <a href="/" class="btn-primary-custom mt-3">
            <i class="fas fa-home"></i> Go Home
        </a>
    </div>
</div>
