@{ Layout = "_Layout"; ViewData["Title"] = "Access Denied"; }
<div class="auth-page">
    <div class="auth-card text-center">
        <i class="fas fa-lock" style="font-size:4rem;color:var(--danger);margin-bottom:1.5rem;"></i>
        <h2 style="-webkit-text-fill-color:var(--text-primary);">Access Denied</h2>
        <p class="subtitle">You do not have permission to access this resource.</p>
        <a href="/" class="btn-primary-custom mt-3"><i class="fas fa-home"></i> Go Home</a>
    </div>
</div>
