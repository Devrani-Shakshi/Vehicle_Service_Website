@{
    Layout = "_Layout";
}
@model ServicePlatform.ViewModels.Account.ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
}

<div class="auth-page">
    <div class="auth-card animate__animated animate__fadeIn">
        <div style="text-align:center;margin-bottom:1.5rem;">
            <i class="fas fa-lock-open" style="font-size:2.5rem;background:var(--primary-gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent;"></i>
        </div>
        <h2>Reset Password</h2>
        <p class="subtitle">Create a new password for your account</p>

        @if (TempData["Error"] != null)
        {
            <div style="color:var(--danger);font-size:0.85rem;margin-bottom:1rem;text-align:center;background:rgba(239,68,68,0.1);padding:10px;border-radius:8px;">
                @TempData["Error"]
            </div>
        }

        <div asp-validation-summary="ModelOnly" style="color:var(--danger);font-size:0.85rem;margin-bottom:1rem;text-align:center;background:rgba(239,68,68,0.1);padding:10px;border-radius:8px;"></div>

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Email" />

            <div class="form-floating-custom">
                <label asp-for="NewPassword">New Password</label>
                <input asp-for="NewPassword" type="password" class="form-control" placeholder="Enter new password" autofocus />
                <i class="fas fa-lock input-icon"></i>
                <span asp-validation-for="NewPassword" style="color:var(--danger);font-size:0.8rem;"></span>
            </div>

            <div class="form-floating-custom">
                <label asp-for="ConfirmPassword">Confirm New Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm new password" />
                <i class="fas fa-lock input-icon"></i>
                <span asp-validation-for="ConfirmPassword" style="color:var(--danger);font-size:0.8rem;"></span>
            </div>

            <button type="submit" class="btn-primary-custom" style="width:100%;justify-content:center;">
                <i class="fas fa-save"></i> Reset Password
            </button>
        </form>

        <p style="text-align:center;margin-top:1.5rem;color:var(--text-secondary);font-size:0.9rem;">
            <a href="/Account/Login"><i class="fas fa-arrow-left"></i> Back to Sign In</a>
        </p>
    </div>
</div>
