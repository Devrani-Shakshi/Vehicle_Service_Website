@{
    Layout = "_Layout";
}
@model ServicePlatform.ViewModels.Account.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-page">
    <div class="auth-card animate__animated animate__fadeIn">
        <div style="text-align:center;margin-bottom:1.5rem;">
            <i class="fas fa-key" style="font-size:2.5rem;background:var(--primary-gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent;"></i>
        </div>
        <h2>Forgot Password</h2>
        <p class="subtitle">Enter your registered email to receive a one-time password</p>

        @if (TempData["Error"] != null)
        {
            <div style="color:var(--danger);font-size:0.85rem;margin-bottom:1rem;text-align:center;background:rgba(239,68,68,0.1);padding:10px;border-radius:8px;">
                @TempData["Error"]
            </div>
        }

        <div asp-validation-summary="ModelOnly" style="color:var(--danger);font-size:0.85rem;margin-bottom:1rem;text-align:center;background:rgba(239,68,68,0.1);padding:10px;border-radius:8px;"></div>

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()

            <div class="form-floating-custom">
                <label asp-for="Email">Email Address</label>
                <input asp-for="Email" type="email" class="form-control" placeholder="your@@email.com" autofocus />
                <i class="fas fa-envelope input-icon"></i>
                <span asp-validation-for="Email" style="color:var(--danger);font-size:0.8rem;"></span>
            </div>

            <button type="submit" class="btn-primary-custom" style="width:100%;justify-content:center;">
                <i class="fas fa-paper-plane"></i> Send OTP
            </button>
        </form>

        <p style="text-align:center;margin-top:1.5rem;color:var(--text-secondary);font-size:0.9rem;">
            Remember your password? <a href="/Account/Login">Sign In</a>
        </p>
    </div>
</div>
