@{
    Layout = "_Layout";
}
@model ServicePlatform.ViewModels.Account.VerifyOtpViewModel

@{
    ViewData["Title"] = "Verify OTP";
}

<div class="auth-page">
    <div class="auth-card animate__animated animate__fadeIn">
        <div style="text-align:center;margin-bottom:1.5rem;">
            <i class="fas fa-shield-alt" style="font-size:2.5rem;background:var(--primary-gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent;"></i>
        </div>
        <h2>Verify OTP</h2>
        <p class="subtitle">Enter the 6-digit code sent to <strong>@Model.Email</strong></p>

        @if (TempData["DemoOTP"] != null)
        {
            <div style="background:linear-gradient(135deg, rgba(99,102,241,0.15), rgba(59,130,246,0.15));border:2px solid rgba(99,102,241,0.4);border-radius:12px;padding:20px;margin-bottom:1.5rem;text-align:center;">
                <div style="font-size:0.8rem;color:var(--text-muted);margin-bottom:8px;">
                    <i class="fas fa-info-circle"></i> Your OTP (auto-generated since email service is not configured)
                </div>
                <div style="font-size:2rem;font-weight:800;letter-spacing:10px;color:var(--primary-light);font-family:monospace;">
                    @TempData["DemoOTP"]
                </div>
                <div style="font-size:0.75rem;color:var(--text-muted);margin-top:8px;">
                    Copy this code and paste it below
                </div>
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div style="color:var(--success);font-size:0.85rem;margin-bottom:1rem;text-align:center;background:rgba(16,185,129,0.1);padding:10px;border-radius:8px;">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div style="color:var(--danger);font-size:0.85rem;margin-bottom:1rem;text-align:center;background:rgba(239,68,68,0.1);padding:10px;border-radius:8px;">
                @TempData["Error"]
            </div>
        }

        <div asp-validation-summary="ModelOnly" style="color:var(--danger);font-size:0.85rem;margin-bottom:1rem;text-align:center;background:rgba(239,68,68,0.1);padding:10px;border-radius:8px;"></div>

        <form asp-action="VerifyOtp" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Email" />

            <div class="form-floating-custom">
                <label asp-for="Otp">Enter OTP</label>
                <input asp-for="Otp" type="text" class="form-control" placeholder="Enter 6-digit OTP"
                       maxlength="6" style="text-align:center;font-size:1.5rem;letter-spacing:8px;font-weight:700;" autofocus />
                <i class="fas fa-lock input-icon"></i>
                <span asp-validation-for="Otp" style="color:var(--danger);font-size:0.8rem;"></span>
            </div>

            <button type="submit" class="btn-primary-custom" style="width:100%;justify-content:center;">
                <i class="fas fa-check-circle"></i> Verify OTP
            </button>
        </form>

        <p style="text-align:center;margin-top:1rem;color:var(--text-muted);font-size:0.8rem;">
            OTP expires in 10 minutes
        </p>

        <p style="text-align:center;margin-top:0.5rem;color:var(--text-secondary);font-size:0.9rem;">
            Didn't receive it? <a href="/Account/ForgotPassword">Resend OTP</a>
        </p>
    </div>
</div>
