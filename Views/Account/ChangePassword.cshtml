@model ServicePlatform.ViewModels.Account.ChangePasswordViewModel
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Change Password"; }

<div style="width: 100%; max-width: 500px; margin: 0 auto; padding-bottom: 3rem;">
    <div class="data-card animate-fadeInUp">
        <div class="data-card-header">
            <h4 style="margin:0;"><i class="fas fa-key" style="margin-right:10px; color:var(--primary-light);"></i>Change Password</h4>
        </div>
        <div class="data-card-body" style="padding:2rem;">
            <form asp-action="ChangePassword" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:1.5rem; font-size:0.9rem;"></div>
                
                <div style="margin-bottom:1.5rem;">
                    <label asp-for="CurrentPassword" style="display:block; margin-bottom:0.5rem; font-size:0.85rem; font-weight:600; color:var(--text-secondary);"></label>
                    <input asp-for="CurrentPassword" class="form-control-custom" placeholder="••••••••" />
                    <span asp-validation-for="CurrentPassword" class="text-danger" style="font-size:0.8rem;"></span>
                </div>

                <div style="margin-bottom:1.5rem;">
                    <label asp-for="NewPassword" style="display:block; margin-bottom:0.5rem; font-size:0.85rem; font-weight:600; color:var(--text-secondary);"></label>
                    <input asp-for="NewPassword" class="form-control-custom" placeholder="••••••••" />
                    <span asp-validation-for="NewPassword" class="text-danger" style="font-size:0.8rem;"></span>
                    <p style="font-size:0.75rem; color:var(--text-muted); margin-top:0.4rem;">Must have at least 8 chars, 1 uppercase, 1 lowercase, 1 number, and 1 special character.</p>
                </div>

                <div style="margin-bottom:2rem;">
                    <label asp-for="ConfirmPassword" style="display:block; margin-bottom:0.5rem; font-size:0.85rem; font-weight:600; color:var(--text-secondary);"></label>
                    <input asp-for="ConfirmPassword" class="form-control-custom" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:0.8rem;"></span>
                </div>

                <div style="display:flex; gap:1rem;">
                    <button type="submit" class="btn-primary-custom" style="flex:1;">Update Password</button>
                    <a href="javascript:history.back()" class="btn-outline-custom" style="flex:1; text-align:center;">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
