@{
    Layout = "_Layout";
}
@model ServicePlatform.ViewModels.Account.RegisterViewModel

@{
    ViewData["Title"] = "Create Account";
}

<div class="auth-page">
    <div class="auth-card animate-fadeInUp">
        <div style="text-align:center;margin-bottom:1.5rem;">
            <i class="fas fa-bolt" style="font-size:2.5rem;background:var(--primary-gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent;animation:pulse 2s infinite;"></i>
        </div>
        <h2>Create Account</h2>
        <p class="subtitle">Join ServicePlatform and get started</p>

        <div asp-validation-summary="ModelOnly" style="color:var(--danger);font-size:0.85rem;margin-bottom:1rem;text-align:center;"></div>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div class="form-floating-custom">
                <label asp-for="FullName">Full Name</label>
                <div class="input-group-custom">
                    <input asp-for="FullName" class="form-control" placeholder="Enter your full name" />
                    <i class="fas fa-user input-icon"></i>
                </div>
                <span asp-validation-for="FullName" style="color:var(--danger);font-size:0.8rem;"></span>
            </div>

            <div class="form-floating-custom">
                <label asp-for="Email">Email Address</label>
                <div class="input-group-custom">
                    <input asp-for="Email" type="email" class="form-control" placeholder="your@email.com" oninput="validateStrictEmail(this)" />
                    <i class="fas fa-envelope input-icon"></i>
                </div>
                <span asp-validation-for="Email" style="color:var(--danger);font-size:0.8rem;"></span>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                <div class="form-floating-custom">
                    <label asp-for="Mobile">Mobile</label>
                    <div class="input-group-custom">
                        <input asp-for="Mobile" class="form-control" placeholder="9876543210" />
                        <i class="fas fa-phone input-icon"></i>
                    </div>
                    <span asp-validation-for="Mobile" style="color:var(--danger);font-size:0.8rem;"></span>
                </div>
                <div class="form-floating-custom">
                    <label asp-for="State">State</label>
                    <div class="input-group-custom">
                        <select asp-for="State" class="form-control">
                            <option value="">Select State</option>
                            @foreach (var state in (ViewBag.States as string[]) ?? Array.Empty<string>())
                            {
                                <option value="@state">@state</option>
                            }
                        </select>
                        <i class="fas fa-map-marker-alt input-icon"></i>
                    </div>
                    <span asp-validation-for="State" style="color:var(--danger);font-size:0.8rem;"></span>
                </div>
            </div>

            <div class="form-floating-custom">
                <label asp-for="Role">Register As</label>
                <div class="input-group-custom">
                    <select asp-for="Role" class="form-control">
                        <option value="User">User</option>
                        <option value="ServiceProvider">Service Provider</option>
                        <option value="Shopkeeper">Shopkeeper</option>
                    </select>
                    <i class="fas fa-user-tag input-icon"></i>
                </div>
                <span asp-validation-for="Role" style="color:var(--danger);font-size:0.8rem;"></span>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                <div class="form-floating-custom">
                    <label asp-for="Password">Password</label>
                    <div class="input-group-custom">
                        <input asp-for="Password" type="password" class="form-control" placeholder="Min 8 characters" id="reg-password" />
                        <i class="fas fa-lock input-icon"></i>
                        <i class="fas fa-eye password-toggle" onclick="togglePasswordVisibility('reg-password', this)"></i>
                    </div>
                    <span asp-validation-for="Password" style="color:var(--danger);font-size:0.8rem;"></span>
                </div>
                <div class="form-floating-custom">
                    <label asp-for="ConfirmPassword">Confirm</label>
                    <div class="input-group-custom">
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Re-enter password" id="reg-confirm" />
                        <i class="fas fa-lock input-icon"></i>
                        <i class="fas fa-eye password-toggle" onclick="togglePasswordVisibility('reg-confirm', this)"></i>
                    </div>
                    <span asp-validation-for="ConfirmPassword" style="color:var(--danger);font-size:0.8rem;"></span>
                </div>
            </div>

            <button type="submit" class="btn-primary-custom" style="width:100%;justify-content:center;margin-top:0.5rem;">
                <i class="fas fa-user-plus"></i> Create Account
            </button>
        </form>

        </p>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const emailInput = document.querySelector('input[type="email"]');
            
            if (emailInput) {
                emailInput.addEventListener('input', function () {
                    validateStrictEmail(this);
                });
            }

            // Register toggles
            window.togglePasswordVisibility = function(inputId, icon) {
                const input = document.getElementById(inputId);
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.replace('fa-eye', 'fa-eye-slash');
                } else {
                    input.type = 'password';
                    icon.classList.replace('fa-eye-slash', 'fa-eye');
                }
            };
        });
    </script>
}
