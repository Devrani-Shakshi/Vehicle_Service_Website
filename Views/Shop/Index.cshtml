@model ServicePlatform.ViewModels.Shop.ShopCatalogViewModel
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Shop"; }

<!-- Search and Filters -->
<div class="data-card animate-fadeInUp" style="margin-bottom:1.5rem;">
    <div class="data-card-body" style="padding:1.5rem;">
        <form method="get" asp-controller="Shop" asp-action="Index" style="display:flex;gap:1.5rem;flex-wrap:wrap;align-items:flex-end;">
            <div class="form-floating-custom" style="flex:1;min-width:250px;margin-bottom:0;">
                <label style="font-weight:600; color:var(--primary-light);">Search Products</label>
                <input name="search" value="@Model.SearchTerm" class="form-control" placeholder="What are you looking for?" />
            </div>
            <div class="form-floating-custom" style="width:200px;margin-bottom:0;">
                <label>Category</label>
                <select name="category" class="form-control" onchange="this.form.submit()">
                    <option value="">All Categories</option>
                    @foreach (var c in Model.Categories) { <option value="@c" selected="@(Model.Category == c)">@c</option> }
                </select>
            </div>
            <div class="form-floating-custom" style="width:180px;margin-bottom:0;">
                <label>Sort By</label>
                <select name="sortBy" class="form-control" onchange="this.form.submit()">
                    <option value="newest" selected="@(Model.SortBy == "newest")">Newest</option>
                    <option value="price_asc" selected="@(Model.SortBy == "price_asc")">Price: Low to High</option>
                    <option value="price_desc" selected="@(Model.SortBy == "price_desc")">Price: High to Low</option>
                    <option value="name" selected="@(Model.SortBy == "name")">Name (A-Z)</option>
                </select>
            </div>
            <button type="submit" class="btn-primary-custom" style="padding:16px 32px;margin-bottom:0;height:56px;"><i class="fas fa-search"></i> Search</button>
        </form>
    </div>
</div>

<!-- Product Grid -->
<div class="product-grid">
    @foreach (var p in Model.Products)
    {
        <div class="product-card animate-fadeInUp">
            <div class="product-image">
                @if (!string.IsNullOrEmpty(p.ImageUrl))
                {
                    <img src="@p.ImageUrl" alt="@p.Name" />
                }
                else
                {
                    <i class="fas fa-box"></i>
                }
            </div>
            <div class="product-info">
                <div class="product-category">@(p.Category ?? "Uncategorized")</div>
                <h5>@p.Name</h5>
                <div class="product-price">
                    @if (p.DiscountPrice.HasValue)
                    {
                        <span class="current">₹@p.DiscountPrice.Value.ToString("N0")</span>
                        <span class="original">₹@p.Price.ToString("N0")</span>
                    }
                    else
                    {
                        <span class="current">₹@p.Price.ToString("N0")</span>
                    }
                </div>
                <div style="display:flex;gap:8px;">
                    <a href="/Shop/ProductDetails/@p.Id" class="btn-outline-custom" style="flex:1;justify-content:center;padding:8px;font-size:0.85rem;" 
                       data-bs-toggle="tooltip" data-bs-title="View product details"><i class="fas fa-eye"></i> View</a>
                    <form asp-controller="Shop" asp-action="AddToCart" method="post" style="flex:1;">
                        <input type="hidden" name="productId" value="@p.Id" />
                        <button type="submit" class="btn-primary-custom" style="width:100%;justify-content:center;padding:8px;font-size:0.85rem;"
                                data-bs-toggle="tooltip" data-bs-title="Add to shopping cart"><i class="fas fa-cart-plus"></i> Add</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Products.Any())
{
    <div class="empty-state" style="margin-top:3rem;">
        <i class="fas fa-store-slash"></i>
        <h5>No products found</h5>
        <p>Try adjusting your search or filters</p>
    </div>
}

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <div class="pagination-custom">
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <a href="?search=@Model.SearchTerm&category=@Model.Category&sortBy=@Model.SortBy&page=@i" class="@(i == Model.CurrentPage ? "active" : "")">@i</a>
        }
    </div>
}
