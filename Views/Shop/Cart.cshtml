@model ServicePlatform.ViewModels.Shop.CartViewModel
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Shopping Cart"; }

<div style="display:grid;grid-template-columns:2fr 1fr;gap:1.5rem;">
    <div class="data-card animate-fadeInUp">
        <div class="data-card-header">
            <h5><i class="fas fa-shopping-cart" style="color:var(--primary-light);margin-right:8px;"></i>Cart (@Model.Items.Count items)</h5>
        </div>
        @if (Model.Items.Any())
        {
            @foreach (var item in Model.Items)
            {
                <div class="cart-item">
                    <div class="cart-item-image">
                        @if (!string.IsNullOrEmpty(item.ImageUrl)) { <img src="@item.ImageUrl" alt="@item.ProductName" /> }
                        else { <i class="fas fa-box" style="font-size:1.5rem;"></i> }
                    </div>
                    <div style="flex:1;">
                        <h6 style="font-weight:600;margin-bottom:4px;">@item.ProductName</h6>
                        <p style="color:var(--success);font-weight:700;margin:0;">₹@item.UnitPrice.ToString("N0")</p>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;">
                        <form asp-action="UpdateCartItem" method="post" style="display:flex;align-items:center;gap:6px;">
                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                            <button type="submit" name="quantity" value="@(item.Quantity - 1)" class="btn-outline-custom" style="padding:6px 10px;font-size:0.8rem;">−</button>
                            <span style="font-weight:700;min-width:30px;text-align:center;">@item.Quantity</span>
                            <button type="submit" name="quantity" value="@(item.Quantity + 1)" class="btn-outline-custom" style="padding:6px 10px;font-size:0.8rem;">+</button>
                        </form>
                    </div>
                    <div style="text-align:right;min-width:100px;">
                        <p style="font-weight:700;margin:0;">₹@item.TotalPrice.ToString("N0")</p>
                        <form asp-action="RemoveCartItem" method="post"><input type="hidden" name="cartItemId" value="@item.CartItemId" /><button type="submit" style="background:none;border:none;color:var(--danger);cursor:pointer;font-size:0.8rem;"><i class="fas fa-trash"></i> Remove</button></form>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state"><i class="fas fa-cart-arrow-down"></i><h5>Cart is empty</h5><p>Browse the shop and add products</p><a href="/Shop" class="btn-primary-custom" style="margin-top:1rem;"><i class="fas fa-store"></i> Go to Shop</a></div>
        }
    </div>

    @if (Model.Items.Any())
    {
        <div class="cart-summary animate-fadeInUp-delay-1">
            <h5>Order Summary</h5>
            <div class="summary-row"><span>Subtotal</span><span>₹@Model.SubTotal.ToString("N2")</span></div>
            <div class="summary-row"><span>Tax (18% GST)</span><span>₹@Model.Tax.ToString("N2")</span></div>
            <div class="summary-row total"><span>Total</span><span>₹@Model.Total.ToString("N2")</span></div>
            <a href="/Shop/Checkout" class="btn-primary-custom" style="width:100%;justify-content:center;margin-top:1rem;"><i class="fas fa-lock"></i> Secure Checkout</a>
        </div>
    }
</div>
