@model ServicePlatform.Models.ChargingStation
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Add Charging Station"; }

<div style="width:100%;max-width:650px;margin:0 auto;padding-bottom:2rem;">
    <div class="data-card animate-fadeInUp">
        <div class="data-card-header"><h5><i class="fas fa-charging-station" style="color:var(--success);margin-right:8px;"></i>Add Charging Station</h5></div>
        <div class="data-card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="form-floating-custom"><label asp-for="Name">Station Name</label><input asp-for="Name" class="form-control" placeholder="e.g. Tata Power EV Station" /><span asp-validation-for="Name" style="color:var(--danger);font-size:0.8rem;"></span></div>
                <div class="form-floating-custom"><label asp-for="Address">Full Address</label><input asp-for="Address" class="form-control" /><span asp-validation-for="Address" style="color:var(--danger);font-size:0.8rem;"></span></div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                    <div class="form-floating-custom"><label asp-for="City">City</label><input asp-for="City" class="form-control" /><span asp-validation-for="City" style="color:var(--danger);font-size:0.8rem;"></span></div>
                    <div class="form-floating-custom"><label asp-for="State">State</label><input asp-for="State" class="form-control" /></div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                    <div class="form-floating-custom"><label asp-for="Latitude">Latitude</label><input asp-for="Latitude" type="number" step="0.000001" class="form-control" /></div>
                    <div class="form-floating-custom"><label asp-for="Longitude">Longitude</label><input asp-for="Longitude" type="number" step="0.000001" class="form-control" /></div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                    <div class="form-floating-custom"><label asp-for="ConnectorTypes">Connector Types</label><input asp-for="ConnectorTypes" class="form-control" placeholder="Type 2, CCS, CHAdeMO" /></div>
                    <div class="form-floating-custom"><label asp-for="PowerOutput">Power Output</label><input asp-for="PowerOutput" class="form-control" placeholder="50kW" /></div>
                </div>
                <button type="submit" class="btn-primary-custom" style="width:100%;justify-content:center;margin-top:1rem;"><i class="fas fa-plus"></i> Add Station</button>
            </form>
        </div>
    </div>
</div>
