@model ServicePlatform.ViewModels.Service.UserDashboardViewModel
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Dashboard"; }

<h4 class="animate-fadeInUp" style="margin-bottom:0.25rem;">Welcome back, <span style="background:var(--primary-gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">@Model.UserName</span></h4>
<p class="animate-fadeInUp" style="color:var(--text-muted);margin-bottom:2rem;">Here's an overview of your activity</p>

<!-- Stats -->
<div class="stats-grid">
    <div class="stat-card animate-fadeInUp"><div class="stat-icon warning"><i class="fas fa-clock"></i></div><div class="stat-info"><h3>@Model.PendingRequests</h3><p>Pending Requests</p></div></div>
    <div class="stat-card animate-fadeInUp-delay-1"><div class="stat-icon success"><i class="fas fa-check-circle"></i></div><div class="stat-info"><h3>@Model.CompletedRequests</h3><p>Completed</p></div></div>
    <div class="stat-card animate-fadeInUp-delay-2"><div class="stat-icon info"><i class="fas fa-shopping-bag"></i></div><div class="stat-info"><h3>@Model.TotalOrders</h3><p>Total Orders</p></div></div>
    <div class="stat-card animate-fadeInUp-delay-3"><div class="stat-icon primary"><i class="fas fa-calendar-alt"></i></div><div class="stat-info"><h3>@Model.UpcomingAppointments</h3><p>Appointments</p></div></div>
</div>

<!-- Quick Actions -->
<div class="data-card animate-fadeInUp-delay-2" style="margin-bottom:1.5rem;">
    <div class="data-card-header"><h5><i class="fas fa-zap" style="color:var(--accent);margin-right:8px;"></i>Quick Actions</h5></div>
    <div class="data-card-body">
        <div class="quick-actions">
            <a href="/UserDashboard/CreateRequest" class="quick-action-card"><i class="fas fa-plus-circle"></i><span>New Service Request</span></a>
            <a href="/UserDashboard/BookAppointment" class="quick-action-card"><i class="fas fa-calendar-plus"></i><span>Book Appointment</span></a>
            <a href="/Shop" class="quick-action-card"><i class="fas fa-store"></i><span>Browse Shop</span></a>
            <a href="/Shop/Cart" class="quick-action-card"><i class="fas fa-shopping-cart"></i><span>View Cart</span></a>
            <a href="/UserDashboard/Feedback" class="quick-action-card"><i class="fas fa-comment-dots"></i><span>Send Feedback</span></a>
            <a href="/UserDashboard/Settings" class="quick-action-card"><i class="fas fa-cog"></i><span>Settings</span></a>
        </div>
    </div>
</div>

<!-- Recent Activity -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;">
    <div class="data-card animate-fadeInUp-delay-3">
        <div class="data-card-header">
            <h5 style="display:flex;align-items:center;gap:8px;">Recent Service Requests</h5>
            <input type="text" id="requestSearch" class="form-control" placeholder="Search..." style="width:120px;padding:4px 8px;font-size:0.75rem;" />
        </div>
        <table class="table-custom" id="requestsTable">
            <thead><tr><th>Request</th><th>Status</th><th>Date</th></tr></thead>
            <tbody>
                @foreach (var r in Model.RecentRequests)
                {
                    <tr>
                        <td><a href="/UserDashboard/RequestDetails/@r.Id">@r.Title</a></td>
                        <td><span class="badge-custom badge-@r.Status.ToString().ToLower()">@r.Status</span></td>
                        <td style="font-size:0.8rem;color:var(--text-muted);">@r.CreatedAt.ToString("MMM dd")</td>
                    </tr>
                }
                @if (!Model.RecentRequests.Any())
                {
                    <tr><td colspan="3" class="empty-state"><i class="fas fa-clipboard"></i><p>No requests yet</p></td></tr>
                }
            </tbody>
        </table>
    </div>
    <div class="data-card animate-fadeInUp-delay-4">
        <div class="data-card-header">
            <h5 style="display:flex;align-items:center;gap:8px;">Upcoming Appointments</h5>
            <input type="text" id="appointmentSearch" class="form-control" placeholder="Search..." style="width:120px;padding:4px 8px;font-size:0.75rem;" />
        </div>
        <table class="table-custom" id="appointmentsTable">
            <thead><tr><th>Appointment</th><th>Date</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var a in Model.UpcomingAppointmentsList)
                {
                    <tr>
                        <td>@a.Title</td>
                        <td style="font-size:0.8rem;color:var(--text-muted);">@a.ScheduledDate.ToString("MMM dd, yyyy")</td>
                        <td><span class="badge-custom badge-@a.Status.ToString().ToLower()">@a.Status</span></td>
                    </tr>
                }
                @if (!Model.UpcomingAppointmentsList.Any())
                {
                    <tr><td colspan="3" class="empty-state"><i class="fas fa-calendar"></i><p>No appointments</p></td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            initTableSearch('requestSearch', 'requestsTable');
            initTableSearch('appointmentSearch', 'appointmentsTable');
        });
    </script>
}
