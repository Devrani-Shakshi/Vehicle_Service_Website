@model ServicePlatform.ViewModels.Service.UserDashboardViewModel
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Dashboard"; }

<h4 class="animate-fadeInUp" style="margin-bottom:0.25rem;">Welcome back, <span style="background:var(--primary-gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">@Model.UserName</span></h4>
<p class="animate-fadeInUp" style="color:var(--text-muted);margin-bottom:2rem;">Here's an overview of your activity</p>

<!-- Stats Grid -->
<div class="stats-grid animate-fadeInUp">
    <div class="stat-card">
        <div class="stat-icon warning"><i class="fas fa-clock"></i></div>
        <div class="stat-info"><h3>@Model.PendingRequests</h3><p>Pending</p></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon success"><i class="fas fa-check-circle"></i></div>
        <div class="stat-info"><h3>@Model.CompletedRequests</h3><p>Completed</p></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon info"><i class="fas fa-shopping-bag"></i></div>
        <div class="stat-info"><h3>@Model.TotalOrders</h3><p>Orders</p></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon primary"><i class="fas fa-calendar-alt"></i></div>
        <div class="stat-info"><h3>@Model.UpcomingAppointments</h3><p>Events</p></div>
    </div>
</div>

<!-- Vehicle Analytics Card -->
<div class="data-card animate-fadeInUp" style="margin-bottom: 2rem;">
    <div class="data-card-header">
        <h5><i class="fas fa-heartbeat" style="color:var(--danger);margin-right:8px;"></i>Vehicle Health Trends</h5>
    </div>
    <div class="data-card-body" style="height:280px; padding: 20px;">
        @if (Model.BatteryHealthHistory != null && Model.BatteryHealthHistory.Any()) {
            <canvas id="healthChart"></canvas>
        } else {
            <div class="empty-state" style="padding-top: 50px;">
                <i class="fas fa-chart-line" style="font-size: 2rem; margin-bottom: 1rem; opacity: 0.3;"></i>
                <p>No health analytics available yet.</p>
            </div>
        }
    </div>
</div>

<div class="row">
    <!-- Action Cards -->
    <div class="col-lg-6">
        <div class="data-card animate-fadeInUp" style="height: 100%;">
            <div class="data-card-header"><h5><i class="fas fa-bolt" style="color:var(--accent);margin-right:8px;"></i>Quick Actions</h5></div>
            <div class="data-card-body">
                <div class="quick-actions" style="display:grid; grid-template-columns: 1fr 1fr; gap:12px;">
                    <a href="/UserDashboard/CreateRequest" class="quick-action-card" style="margin:0;"><i class="fas fa-tools"></i><span>Request Service</span></a>
                    <a href="/UserDashboard/BookAppointment" class="quick-action-card" style="margin:0;"><i class="fas fa-calendar-plus"></i><span>Book Appointment</span></a>
                    <a href="/Shop" class="quick-action-card" style="margin:0;"><i class="fas fa-store"></i><span>Visit Shop</span></a>
                    <a href="/Diagnostic" class="quick-action-card" style="margin:0; background:var(--primary-gradient); color:white; border:none;"><i class="fas fa-robot"></i><span>AI Diagnostic Bot</span></a>
                </div>
            </div>
        </div>
    </div>

    <!-- Activity Summary -->
    <div class="col-lg-6">
        <div class="data-card animate-fadeInUp" style="height: 100%;">
            <div class="data-card-header"><h5><i class="fas fa-history" style="margin-right:8px;"></i>Recent History</h5></div>
            <div class="data-card-body" style="padding: 0;">
                <div class="table-responsive">
                    <table class="table-custom" style="margin: 0;">
                        <thead><tr><th>Title</th><th>Status</th></tr></thead>
                        <tbody>
                            @foreach(var r in Model.RecentRequests.Take(3)) {
                                <tr>
                                    <td>@r.Title</td>
                                    <td><span class="badge-custom @r.Status.ToString().ToLower()">@r.Status</span></td>
                                </tr>
                            }
                            @if(!Model.RecentRequests.Any()) {
                                <tr><td colspan="2" class="empty-state" style="padding: 1.5rem;">No recent history.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-6">
        <!-- Recent Requests -->
        <div class="data-card animate-fadeInUp">
            <div class="data-card-header"><h5>Recent Requests</h5></div>
            <table class="table-custom">
                <thead><tr><th>Request</th><th>Status</th></tr></thead>
                <tbody>
                    @foreach(var r in Model.RecentRequests.Take(5)) {
                        <tr><td>@r.Title</td><td><span class="badge-custom @r.Status.ToString().ToLower()">@r.Status</span></td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-lg-6">
        <!-- Upcoming Appointments -->
        <div class="data-card animate-fadeInUp">
            <div class="data-card-header"><h5>Upcoming Appointments</h5></div>
            <table class="table-custom">
                <thead><tr><th>Event</th><th>Date</th></tr></thead>
                <tbody>
                    @foreach(var a in Model.UpcomingAppointmentsList.Take(5)) {
                        <tr><td>@a.Title</td><td>@a.ScheduledDate.ToString("MMM dd")</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ctx = document.getElementById('healthChart');
            if (ctx) {
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: @Html.Raw(Json.Serialize(Model.BatteryHealthHistory?.Select(x => x.Date) ?? new List<string>())),
                        datasets: [{
                            label: 'Battery Health (SOH %)',
                            data: @Html.Raw(Json.Serialize(Model.BatteryHealthHistory?.Select(x => x.Health) ?? new List<int>())),
                            borderColor: '#158081',
                            backgroundColor: 'rgba(21, 128, 129, 0.1)',
                            fill: true,
                            tension: 0.4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: { y: { min: 0, max: 100 } }
                    }
                });
            }
        });
    </script>
}
