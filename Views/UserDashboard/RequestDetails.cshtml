@model ServicePlatform.Models.ServiceRequest
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Request Details"; }

<div style="display:grid;grid-template-columns:2fr 1fr;gap:1.5rem;">
    <div>
        <div class="data-card animate-fadeInUp">
            <div class="data-card-header">
                <h5>@Model.Title</h5>
                <span class="badge-custom badge-@Model.Status.ToString().ToLower()" style="font-size:0.85rem;">@Model.Status</span>
            </div>
            <div class="data-card-body">
                <p style="color:var(--text-secondary);margin-bottom:1.5rem;">@Model.Description</p>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem;">
                    <div><strong style="color:var(--text-muted);font-size:0.8rem;">TYPE</strong><p style="margin:0;">@Model.RequestType</p></div>
                    <div><strong style="color:var(--text-muted);font-size:0.8rem;">CATEGORY</strong><p style="margin:0;">@(Model.Category ?? "N/A")</p></div>
                    <div><strong style="color:var(--text-muted);font-size:0.8rem;">VEHICLE MODEL</strong><p style="margin:0;color:var(--primary-light);">@(Model.VehicleModel?.Name ?? Model.VehicleModelName ?? "General EV")</p></div>
                    <div><strong style="color:var(--text-muted);font-size:0.8rem;">BATTERY HEALTH</strong><p style="margin:0;color:@(Model.BatteryStateOfHealth < 80 ? "var(--danger)" : "var(--success)"); font-weight:600;">@(Model.BatteryStateOfHealth.HasValue ? Model.BatteryStateOfHealth + "%" : "Not Analyzed")</p></div>
                    <div><strong style="color:var(--text-muted);font-size:0.8rem;">ODOMETER</strong><p style="margin:0;">@(Model.KilometersDriven.HasValue ? Model.KilometersDriven + " KM" : "Unknown")</p></div>
                    <div><strong style="color:var(--text-muted);font-size:0.8rem;">CREATED</strong><p style="margin:0;">@Model.CreatedAt.ToString("MMM dd, yyyy")</p></div>
                </div>
                @if (Model.ServiceProvider != null)
                {
                    <div style="background:var(--bg-primary);border-radius:var(--radius-md);padding:1rem;">
                        <strong style="color:var(--text-muted);font-size:0.8rem;display:block;margin-bottom:0.5rem;">SERVICE PROVIDER</strong>
                        <p style="font-weight:600;margin:0;">@Model.ServiceProvider.FullName</p>
                        <p style="font-size:0.85rem;color:var(--text-muted);margin:0;">@Model.ServiceProvider.Email • @Model.ServiceProvider.Mobile</p>
                    </div>
                }
            </div>
        </div>

        <!-- Rating Section -->
        @if (Model.Status == ServicePlatform.Models.ServiceRequestStatus.Completed && Model.ServiceProvider != null && !Model.Ratings.Any())
        {
            <div class="data-card animate-fadeInUp-delay-1">
                <div class="data-card-header"><h5><i class="fas fa-star" style="color:var(--accent);margin-right:8px;"></i>Rate this Service</h5></div>
                <div class="data-card-body">
                    <form asp-controller="UserDashboard" asp-action="SubmitRating" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="ServiceRequestId" value="@Model.Id" />
                        <input type="hidden" name="ServiceProviderId" value="@Model.ServiceProviderId" />
                        <input type="hidden" name="Stars" id="ratingValue" value="5" />
                        <div class="star-rating-input" id="starRating" style="margin-bottom:1rem;">
                            @for (int i = 1; i <= 5; i++) { <i class="fas fa-star active" data-value="@i" onclick="setRating(@i)"></i> }
                        </div>
                        <textarea name="ReviewText" class="form-control" rows="3" placeholder="Share your experience" style="margin-bottom:1rem;"></textarea>
                        <button type="submit" class="btn-primary-custom"><i class="fas fa-paper-plane"></i> Submit Rating</button>
                    </form>
                </div>
            </div>
        }
    </div>

    <div>
        <!-- Chat Section -->
        <div class="data-card animate-fadeInUp-delay-1" style="margin-bottom:1.5rem;">
            <div class="data-card-header"><h5><i class="fas fa-comments" style="color:var(--info);margin-right:8px;"></i>Support Chat</h5></div>
            <div class="data-card-body" style="display:flex; flex-direction:column; height:400px;">
                <div id="chatMessages" style="flex:1; overflow-y:auto; padding:0.75rem; background:var(--bg-primary); border-radius:var(--radius-md); margin-bottom:0.75rem; display:flex; flex-direction:column; gap:0.5rem;">
                    <div style="text-align:center; color:var(--text-muted); font-size:0.75rem;">Secure chat with provider started.</div>
                </div>
                <div style="display:flex; gap:8px;">
                    <input type="text" id="chatInput" class="form-control" placeholder="Type here..." style="padding:6px 12px; font-size:0.9rem;" />
                    <button id="sendBtn" class="btn-primary-custom" style="padding:0 15px;"><i class="fas fa-paper-plane"></i></button>
                </div>
            </div>
        </div>

        @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
        {
            <div class="data-card animate-fadeInUp-delay-2">
                <div class="data-card-header"><h5><i class="fas fa-map-marker-alt" style="color:var(--danger);margin-right:8px;"></i>Location</h5></div>
                <div class="data-card-body" style="padding:0;">
                    <div id="locationMap" class="map-container" style="height:250px; border-radius:0 0 var(--radius-lg) var(--radius-lg);"></div>
                </div>
            </div>
        }
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
}

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
            {
                <text>
                var map = L.map('locationMap').setView([@Model.Latitude, @Model.Longitude], 15);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' }).addTo(map);
                L.marker([@Model.Latitude, @Model.Longitude]).addTo(map).bindPopup('<strong>Service Location</strong>').openPopup();
                </text>
            }

            // --- SignalR Chat ---
            const chatConnection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/chat")
                .withAutomaticReconnect()
                .build();

            chatConnection.on("ReceiveMessage", function(user, message, time) {
                const msgList = document.getElementById("chatMessages");
                const isMine = user === "@User.Identity?.Name";
                const msgHtml = `
                    <div style="align-self: ${isMine ? 'flex-end' : 'flex-start'}; max-width: 85%;">
                        <div style="background: ${isMine ? 'var(--primary)' : 'var(--bg-card)'}; color: ${isMine ? 'white' : 'var(--text-primary)'}; padding: 6px 10px; border-radius: 10px; border-bottom-${isMine ? 'right' : 'left'}-radius: 2px; box-shadow: var(--shadow-sm); font-size: 0.85rem;">
                            ${message}
                        </div>
                        <div style="font-size: 0.65rem; color: var(--text-muted); margin-top: 1px; text-align: ${isMine ? 'right' : 'left'}">${time}</div>
                    </div>
                `;
                msgList.insertAdjacentHTML('beforeend', msgHtml);
                msgList.scrollTop = msgList.scrollHeight;
            });

            chatConnection.start().then(() => {
                chatConnection.invoke("JoinGroup", "@Model.Id");
            }).catch(err => console.error(err));

            document.getElementById("sendBtn").addEventListener("click", sendMessage);
            document.getElementById("chatInput").addEventListener("keypress", e => { if(e.key === 'Enter') sendMessage(); });

            function sendMessage() {
                const input = document.getElementById("chatInput");
                const msg = input.value.trim();
                if(msg) {
                    chatConnection.invoke("SendMessage", "@Model.Id", "@User.Identity?.Name", msg);
                    input.value = "";
                }
            }
        });

        function setRating(val) {
            document.getElementById('ratingValue').value = val;
            document.querySelectorAll('#starRating i').forEach((star, i) => { star.classList.toggle('active', i < val); });
        }
    </script>
}
