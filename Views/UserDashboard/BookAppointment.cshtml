@model ServicePlatform.ViewModels.Service.AppointmentViewModel
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Book Appointment"; }

<div style="width: 100%; padding-bottom: 2rem;">
    <div class="data-card animate-fadeInUp">
        <div class="data-card-header"><h5><i class="fas fa-calendar-plus" style="color:var(--primary-light);margin-right:8px;"></i>Book Appointment</h5></div>
        <div class="data-card-body">
            <form asp-action="BookAppointment" method="post" id="appointmentForm">
                @Html.AntiForgeryToken()
                <div class="form-floating-custom"><label asp-for="Title">Appointment Title</label><input asp-for="Title" class="form-control" placeholder="Brief description" /><span asp-validation-for="Title" style="color:var(--danger);font-size:0.8rem;"></span></div>
                <div class="form-floating-custom"><label asp-for="Description">Description</label><textarea asp-for="Description" class="form-control" rows="3" placeholder="Details about the appointment"></textarea></div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                    <div class="form-floating-custom">
                        <label asp-for="ScheduledDate">Date</label>
                        <input asp-for="ScheduledDate" type="date" class="form-control" id="appointmentDate" />
                        <span asp-validation-for="ScheduledDate" style="color:var(--danger);font-size:0.8rem;"></span>
                        <small id="dateError" style="color:var(--danger);font-size:0.8rem;display:none;"></small>
                    </div>
                    <div class="form-floating-custom">
                        <label asp-for="TimeSlot">Time Slot</label>
                        <select asp-for="TimeSlot" class="form-control">
                            <option value="">Select Time</option>
                            <option>09:00 AM - 10:00 AM</option><option>10:00 AM - 11:00 AM</option><option>11:00 AM - 12:00 PM</option>
                            <option>12:00 PM - 01:00 PM</option><option>02:00 PM - 03:00 PM</option><option>03:00 PM - 04:00 PM</option>
                            <option>04:00 PM - 05:00 PM</option><option>05:00 PM - 06:00 PM</option>
                        </select>
                    </div>
                </div>

                <div style="background:rgba(99, 102, 241, 0.1);border:1px solid rgba(99, 102, 241, 0.2);border-radius:var(--radius-sm);padding:12px 16px;margin-bottom:1.5rem;display:flex;align-items:center;gap:10px;">
                    <i class="fas fa-info-circle" style="color:var(--primary-light);"></i>
                    <small style="color:var(--text-secondary);" data-i18n="appointment_note">Your appointment will remain in <strong>"Requested"</strong> status until a service provider confirms and schedules it.</small>
                </div>

                <button type="submit" class="btn-primary-custom" style="width:100%;justify-content:center;"><i class="fas fa-calendar-check"></i> Book Appointment</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const dateInput = document.getElementById('appointmentDate');
            const dateError = document.getElementById('dateError');
            const form = document.getElementById('appointmentForm');

            // Set min date to today
            const today = new Date();
            const todayStr = today.getFullYear() + '-' +
                String(today.getMonth() + 1).padStart(2, '0') + '-' +
                String(today.getDate()).padStart(2, '0');
            dateInput.setAttribute('min', todayStr);

            // Set default to tomorrow
            const tomorrow = new Date(today);
            tomorrow.setDate(tomorrow.getDate() + 1);
            const tomorrowStr = tomorrow.getFullYear() + '-' +
                String(tomorrow.getMonth() + 1).padStart(2, '0') + '-' +
                String(tomorrow.getDate()).padStart(2, '0');

            if (!dateInput.value) {
                dateInput.value = tomorrowStr;
            }

            // Validate on change
            dateInput.addEventListener('change', function() {
                validateDate();
            });

            // Validate on form submit
            form.addEventListener('submit', function(e) {
                if (!validateDate()) {
                    e.preventDefault();
                }
            });

            function validateDate() {
                const selectedDate = new Date(dateInput.value);
                const todayMidnight = new Date(today.getFullYear(), today.getMonth(), today.getDate());

                if (selectedDate < todayMidnight) {
                    dateError.textContent = 'Cannot book appointments for past dates. Please select today or a future date.';
                    dateError.style.display = 'block';
                    dateInput.style.borderColor = 'var(--danger)';
                    return false;
                } else {
                    dateError.style.display = 'none';
                    dateInput.style.borderColor = '';
                    return true;
                }
            }
        });
    </script>
}
