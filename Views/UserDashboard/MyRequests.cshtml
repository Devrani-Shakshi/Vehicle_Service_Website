@model IEnumerable<ServicePlatform.Models.ServiceRequest>
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "My Service Requests"; }

<div class="data-card animate-fadeInUp">
    <div class="data-card-header">
        <h5><i class="fas fa-clipboard-list" style="color:var(--primary-light);margin-right:8px;"></i>Service Requests</h5>
        <a href="/UserDashboard/CreateRequest" class="btn-primary-custom" style="padding:8px 20px;font-size:0.85rem;"><i class="fas fa-plus"></i> New Request</a>
    </div>
    <table class="table-custom">
        <thead><tr><th>Title</th><th>Type</th><th>Category</th><th>Status</th><th>Provider</th><th>Date</th><th></th></tr></thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td style="font-weight:600;">@r.Title</td>
                    <td><span class="badge-custom badge-@(r.RequestType == ServicePlatform.Models.ServiceRequestType.Urgent ? "danger" : "primary")">@r.RequestType</span></td>
                    <td>@(r.Category ?? "—")</td>
                    <td><span class="badge-custom badge-@r.Status.ToString().ToLower()">@r.Status</span></td>
                    <td>@(r.ServiceProvider?.FullName ?? "Not assigned")</td>
                    <td style="font-size:0.8rem;color:var(--text-muted);">@r.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td><a href="/UserDashboard/RequestDetails/@r.Id" class="btn-outline-custom" style="padding:6px 14px;font-size:0.8rem;">View</a></td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="empty-state"><i class="fas fa-inbox"></i><h5>No requests yet</h5><p>Create your first service request</p></td></tr>
            }
        </tbody>
    </table>
</div>
