@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Platform Policy"; }

<div class="animate-fadeInUp">
    <div class="policy-section">
        <h3><i class="fas fa-shield-alt" style="margin-right:8px;"></i>Terms of Service</h3>
        <ul>
            <li>By using this platform, you agree to our terms and conditions.</li>
            <li>All service requests are subject to availability of service providers.</li>
            <li>Users must provide accurate information during registration.</li>
            <li>Misuse of the platform may result in account suspension.</li>
        </ul>
    </div>
    <div class="policy-section">
        <h3><i class="fas fa-lock" style="margin-right:8px;"></i>Privacy Policy</h3>
        <ul>
            <li>We collect minimal personal data required for service delivery.</li>
            <li>Location data is used only for service request matching.</li>
            <li>Payment information is processed securely through certified gateways.</li>
            <li>We do not share personal data with unauthorized third parties.</li>
        </ul>
    </div>
    <div class="policy-section">
        <h3><i class="fas fa-undo" style="margin-right:8px;"></i>Refund Policy</h3>
        <ul>
            <li>Refunds for service requests are processed within 7 business days.</li>
            <li>Product refunds follow our standard return policy (14 days).</li>
            <li>Contact support for any payment disputes.</li>
        </ul>
    </div>
    <div class="policy-section">
        <h3><i class="fas fa-gavel" style="margin-right:8px;"></i>Service Provider Agreement</h3>
        <ul>
            <li>Service providers must maintain professional conduct.</li>
            <li>Ratings below 2.0 may result in review and potential deactivation.</li>
            <li>Service providers are responsible for their own licenses and insurance.</li>
        </ul>
    </div>
</div>
