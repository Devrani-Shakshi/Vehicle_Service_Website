@model ServicePlatform.Models.Payment
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Invoice"; }

<div style="width:100%;max-width:700px;margin:0 auto;padding-bottom:2rem;">
    <div class="data-card animate-fadeInUp">
        <div class="data-card-header" style="display:block;text-align:center;padding:2rem;">
            <i class="fas fa-file-invoice" style="font-size:2.5rem;color:var(--primary-light);margin-bottom:1rem;display:block;"></i>
            <h4 style="margin:0;">Invoice #INV-@Model.Id.ToString("D6")</h4>
            <p style="color:var(--text-muted);margin:0.5rem 0 0;">@Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")</p>
        </div>
        <div class="data-card-body" style="padding:2rem;">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:2rem;">
                <div>
                    <p style="color:var(--text-muted);font-size:0.8rem;margin:0;">Transaction ID</p>
                    <p style="font-weight:600;margin:0;">@(Model.TransactionId ?? "N/A")</p>
                </div>
                <div>
                    <p style="color:var(--text-muted);font-size:0.8rem;margin:0;">Payment Method</p>
                    <p style="font-weight:600;margin:0;">@Model.PaymentMethod</p>
                </div>
                <div>
                    <p style="color:var(--text-muted);font-size:0.8rem;margin:0;">Status</p>
                    <span class="badge-custom badge-completed">@Model.Status</span>
                </div>
                <div>
                    <p style="color:var(--text-muted);font-size:0.8rem;margin:0;">Amount Paid</p>
                    <p style="font-weight:700;font-size:1.5rem;color:var(--success);margin:0;">₹@Model.Amount.ToString("N2")</p>
                </div>
            </div>
            <hr style="border-color:var(--border-color);margin:1.5rem 0;" />
            <p style="text-align:center;color:var(--text-muted);font-size:0.85rem;">Thank you for using EV ServicePlatform!</p>
            <button onclick="window.print()" class="btn-primary-custom" style="width:100%;justify-content:center;margin-top:1rem;"><i class="fas fa-print"></i> Print Invoice</button>
        </div>
    </div>
</div>
