@model IEnumerable<ServicePlatform.Models.Payment>
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Payment History"; }

<div class="data-card animate-fadeInUp">
    <div class="data-card-header"><h5><i class="fas fa-receipt" style="color:var(--primary-light);margin-right:8px;"></i>Payment History</h5></div>
    <table class="table-custom">
        <thead><tr><th>Transaction</th><th>Amount</th><th>Gateway</th><th>Type</th><th>Status</th><th>Date</th></tr></thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td style="font-family:monospace;font-size:0.8rem;">@(p.TransactionId?[..12] ?? "—")</td>
                    <td style="font-weight:700;color:var(--success);">₹@p.Amount.ToString("N2")</td>
                    <td>@p.Gateway</td>
                    <td>@(p.OrderId.HasValue ? "Order" : "Service")</td>
                    <td><span class="badge-custom badge-@p.Status.ToString().ToLower()">@p.Status</span></td>
                    <td style="font-size:0.8rem;color:var(--text-muted);">@p.CreatedAt.ToString("MMM dd, yyyy")</td>
                </tr>
            }
            @if (!Model.Any()) { <tr><td colspan="6" class="empty-state"><i class="fas fa-receipt"></i><p>No payments yet</p></td></tr> }
        </tbody>
    </table>
</div>
