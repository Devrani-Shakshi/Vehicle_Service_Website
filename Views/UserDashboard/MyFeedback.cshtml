@model IEnumerable<ServicePlatform.Models.Feedback>
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "My Feedback"; }

<div class="data-card animate-fadeInUp">
    <div class="data-card-header"><h5><i class="fas fa-comments" style="color:var(--primary-light);margin-right:8px;"></i>My Feedback</h5><a href="/UserDashboard/Feedback" class="btn-primary-custom" style="padding:8px 20px;font-size:0.85rem;"><i class="fas fa-plus"></i> New</a></div>
    <table class="table-custom">
        <thead><tr><th>Subject</th><th>Category</th><th>Status</th><th>Date</th><th>Response</th></tr></thead>
        <tbody>
            @foreach (var f in Model)
            {
                <tr>
                    <td style="font-weight:600;">@f.Subject</td>
                    <td>@(f.Category ?? "General")</td>
                    <td><span class="badge-custom @(f.IsResolved ? "badge-completed" : "badge-pending")">@(f.IsResolved ? "Resolved" : "Pending")</span></td>
                    <td style="font-size:0.8rem;color:var(--text-muted);">@f.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td style="max-width:200px;font-size:0.85rem;color:var(--text-secondary);">@(f.AdminResponse ?? "—")</td>
                </tr>
            }
            @if (!Model.Any()) { <tr><td colspan="5" class="empty-state"><i class="fas fa-comment-slash"></i><p>No feedback submitted yet</p></td></tr> }
        </tbody>
    </table>
</div>
