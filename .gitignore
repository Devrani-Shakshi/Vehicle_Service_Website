## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This list is a collection of commonly ignored file patterns
## in Visual Studio projects and solutions.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leasePublic/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/lib/

# Visual Studio 2017 AutoGenerated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build log files
*.log
*.txt

# Diagnostic Table Log Files
*.dtable

# Visual Studio Profiler
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Code
.vscode/
*.code-workspace

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core
appsettings.json
appsettings.Development.json
# !appsettings.json # Often kept but can contain secrets

# Entity Framework Core
*.db
*.db-shm
*.db-wal

# NLog
internal-nlog.txt
internal-nlog.log
logs/
Logs/

# Backup and temporary files from editing tools
*~
*.swp
*.bak
*.cache

# OS generated files
.DS_Store
Thumbs.db

# Project specific logs and temporary files
app_startup_log.txt
build_errors*.txt
feedback.txt
project-analysis.txt
project_review.txt
test_plan.txt
testplan.txt
theme-logic.txt
seed_data*.sql.txt
