<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="Logs/nlog-internal.log">

  <extensions>
    <add assembly="NLog.Web.AspNetCore"/>
  </extensions>

  <targets>
    <!-- Console target with colored output -->
    <target xsi:type="Console" name="console"
            layout="${date:format=yyyy-MM-dd HH\:mm\:ss}|${level:uppercase=true}|${logger:shortName=true}|${message}${onexception:${newline}${exception:format=tostring}}" />

    <!-- General application log file (daily rolling) -->
    <target xsi:type="File" name="appFile"
            fileName="Logs/app-${shortdate}.log"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message}|action=${aspnet-mvc-action}|controller=${aspnet-mvc-controller}|url=${aspnet-request-url}|user=${aspnet-user-identity}${onexception:${newline}EXCEPTION: ${exception:format=tostring}}"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="30"
            concurrentWrites="true" />

    <!-- Error-only log file -->
    <target xsi:type="File" name="errorFile"
            fileName="Logs/errors-${shortdate}.log"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message}|action=${aspnet-mvc-action}|controller=${aspnet-mvc-controller}|url=${aspnet-request-url}|user=${aspnet-user-identity}${newline}${exception:format=tostring}"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="60"
            concurrentWrites="true" />

    <!-- Request/Action audit log -->
    <target xsi:type="File" name="auditFile"
            fileName="Logs/audit-${shortdate}.log"
            layout="${longdate}|${aspnet-request-method}|${aspnet-request-url}|${aspnet-response-statuscode}|${aspnet-user-identity}|${aspnet-mvc-controller}|${aspnet-mvc-action}|${message}"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="30"
            concurrentWrites="true" />
  </targets>

  <rules>
    <!-- Skip noisy Microsoft logs -->
    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <logger name="System.Net.Http.*" maxlevel="Info" final="true" />

    <!-- All errors go to error file -->
    <logger name="*" minlevel="Error" writeTo="errorFile" />

    <!-- Audit logging for request middleware -->
    <logger name="ServicePlatform.Middleware.RequestLoggingMiddleware" minlevel="Info" writeTo="auditFile" />

    <!-- All app logs to console and file -->
    <logger name="*" minlevel="Info" writeTo="console,appFile" />
  </rules>
</nlog>
